{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"ContactPage\",\n  data() {\n    return {\n      form: {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      }\n    };\n  },\n  methods: {\n    submitForm() {\n      alert(\"Thank you for reaching out! We will be in touch shortly.\");\n      this.form = {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      };\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver(entries => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, {\n          threshold: 0.1\n        });\n        observer.observe(el);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","form","firstName","lastName","email","phone","message","methods","submitForm","alert","directives","animateOnScroll","mounted","el","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","classList","add","unobserve","threshold","observe"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\Contact.vue"],"sourcesContent":["<template>\n  <div class=\"contact-page\">\n    <!-- Immersive Header Section -->\n    <section class=\"contact-hero\">\n      <div class=\"hero-overlay\"></div>\n      <div class=\"hero-content\" v-animate-on-scroll>\n        <h1 class=\"page-title\">Contact Us</h1>\n        <p class=\"page-subtitle\">We would love to hear from you. Let's start a conversation.</p>\n      </div>\n      <div class=\"scroll-indicator\">\n        <div class=\"mouse\"></div>\n      </div>\n    </section>\n\n    <!-- Main Contact Section -->\n    <section class=\"main-contact container\">\n      <div class=\"redesign-grid\">\n        <!-- Info Column with Enhanced Cards -->\n        <div class=\"info-column\">\n          <div class=\"section-intro\" v-animate-on-scroll>\n            <h2 class=\"script-title\">Get In Touch</h2>\n            <p>Our team is here to help you with any questions or concerns you might have. Reach out via any of the channels below.</p>\n          </div>\n\n          <div class=\"contact-cards\">\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.1s' }\">\n              <div class=\"card-icon\"><i class=\"fas fa-map-marked-alt\"></i></div>\n              <div class=\"card-body\">\n                <h3>Our Bakery</h3>\n                <p>123 Bakery Street, Cochin<br/>Kerala, India 682001</p>\n              </div>\n            </div>\n\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.2s' }\">\n              <div class=\"card-icon\"><i class=\"fas fa-phone-volume\"></i></div>\n              <div class=\"card-body\">\n                <h3>Phone</h3>\n                <p>+91 98765 43210<br/>+91 484 234 5678</p>\n              </div>\n            </div>\n\n            <div class=\"contact-card\" v-animate-on-scroll :style=\"{ transitionDelay: '0.3s' }\">\n              <div class=\"card-icon\"><i class=\"fas fa-paper-plane\"></i></div>\n              <div class=\"card-body\">\n                <h3>Email</h3>\n                <p>hello@cochindistributors.com<br/>support@cochin.dist</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"social-box\" v-animate-on-scroll>\n            <span>Follow our journey</span>\n            <div class=\"social-icons\">\n              <a href=\"#\" class=\"social-btn facebook\"><i class=\"fab fa-facebook-f\"></i></a>\n              <a href=\"#\" class=\"social-btn instagram\"><i class=\"fab fa-instagram\"></i></a>\n              <a href=\"#\" class=\"social-btn twitter\"><i class=\"fab fa-twitter\"></i></a>\n              <a href=\"#\" class=\"social-btn youtube\"><i class=\"fab fa-youtube\"></i></a>\n            </div>\n          </div>\n        </div>\n\n        <!-- Premium Form Column -->\n        <div class=\"form-column\" v-animate-on-scroll>\n          <div class=\"form-premium-card\">\n            <div class=\"card-header\">\n              <i class=\"fas fa-envelope-open-text\"></i>\n              <h3>Send a Message</h3>\n            </div>\n            <form @submit.prevent=\"submitForm\">\n              <div class=\"input-row\">\n                <div class=\"input-group\">\n                  <input type=\"text\" v-model=\"form.firstName\" required placeholder=\" \" />\n                  <label>First Name</label>\n                  <div class=\"bar\"></div>\n                </div>\n                <div class=\"input-group\">\n                  <input type=\"text\" v-model=\"form.lastName\" required placeholder=\" \" />\n                  <label>Last Name</label>\n                  <div class=\"bar\"></div>\n                </div>\n              </div>\n\n              <div class=\"input-group\">\n                <input type=\"email\" v-model=\"form.email\" required placeholder=\" \" />\n                <label>Email Address</label>\n                <div class=\"bar\"></div>\n              </div>\n\n              <div class=\"input-group\">\n                <input type=\"tel\" v-model=\"form.phone\" placeholder=\" \" />\n                <label>Phone (Optional)</label>\n                <div class=\"bar\"></div>\n              </div>\n\n              <div class=\"input-group\">\n                <textarea v-model=\"form.message\" rows=\"4\" required placeholder=\" \"></textarea>\n                <label>How can we help?</label>\n                <div class=\"bar\"></div>\n              </div>\n\n              <button type=\"submit\" class=\"btn-premium\">\n                <span>Submit Message</span>\n                <i class=\"fas fa-long-arrow-alt-right\"></i>\n              </button>\n            </form>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Map Section with decorative framing -->\n    <section class=\"map-immersive\">\n      <div class=\"container map-wrapper\">\n        <div class=\"map-frame\" v-animate-on-scroll>\n          <div class=\"map-inner\">\n             <div class=\"map-marker-floating\">\n               <div class=\"pin\"></div>\n               <div class=\"pulse\"></div>\n             </div>\n             <img src=\"https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&q=80&w=1200\" alt=\"Map Location\" />\n          </div>\n          <div class=\"map-details\">\n            <h2>Find Us Here</h2>\n            <p>Visit us for the freshest experience!</p>\n            <button class=\"btn-link\">Open in Maps <i class=\"fas fa-external-link-alt\"></i></button>\n          </div>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"ContactPage\",\n  data() {\n    return {\n      form: {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\",\n      },\n    };\n  },\n  methods: {\n    submitForm() {\n      alert(\"Thank you for reaching out! We will be in touch shortly.\");\n      this.form = {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\",\n      };\n    },\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver((entries) => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, { threshold: 0.1 });\n        observer.observe(el);\n      }\n    }\n  }\n};\n</script>\n\n<style scoped>\n.contact-page {\n  font-family: 'Plus Jakarta Sans', sans-serif;\n  color: #4a372d;\n  background-color: #fffaf5;\n  padding-top: 80px;\n  overflow-x: hidden;\n}\n\n.container {\n  max-width: 1240px;\n  margin: 0 auto;\n  padding: 0 2rem;\n}\n\n/* --- Hero Section --- */\n.contact-hero {\n  height: 450px;\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  background: url('https://images.unsplash.com/photo-1555507036-ab1f4038808a?auto=format&fit=crop&q=80&w=1400') center/cover no-repeat fixed;\n}\n\n.hero-overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(to bottom, rgba(255,250,245,0.7) 0%, rgba(255,250,245,0.4) 100%);\n}\n\n.page-title {\n  position: relative;\n  z-index: 1;\n  font-family: 'Dancing Script', cursive;\n  font-size: clamp(3.5rem, 8vw, 5.5rem);\n  color: #3e2723;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n}\n\n.page-subtitle {\n  position: relative;\n  z-index: 1;\n  font-size: 1.25rem;\n  color: #6d4c41;\n  font-weight: 500;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n.scroll-indicator {\n  position: absolute;\n  bottom: 30px;\n  left: 50%;\n  transform: translateX(-50%);\n  z-index: 2;\n}\n\n.mouse {\n  width: 25px;\n  height: 40px;\n  border: 2px solid #3e2723;\n  border-radius: 20px;\n  display: flex;\n  justify-content: center;\n  padding-top: 5px;\n}\n\n.mouse::before {\n  content: '';\n  width: 3px;\n  height: 10px;\n  background: #3e2723;\n  border-radius: 2px;\n  animation: scrollDown 2s infinite ease-out;\n}\n\n@keyframes scrollDown {\n  0% { transform: translateY(0); opacity: 1; }\n  100% { transform: translateY(15px); opacity: 0; }\n}\n\n/* --- Main Section Grid --- */\n.main-contact {\n  padding: 10rem 0;\n}\n\n.redesign-grid {\n  display: grid;\n  grid-template-columns: 1fr 1.3fr;\n  gap: 8rem;\n  align-items: start;\n}\n\n/* --- Info Column --- */\n.section-intro {\n  margin-bottom: 4rem;\n  opacity: 0;\n  transform: translateY(20px);\n  transition: all 0.8s ease;\n}\n\n.section-intro.is-visible {\n  opacity: 1; transform: translateY(0);\n}\n\n.script-title {\n  font-family: 'Dancing Script', cursive;\n  font-size: 3.5rem;\n  color: #3e2723;\n  margin-bottom: 1.5rem;\n}\n\n.section-intro p {\n  line-height: 1.8;\n  color: #795548;\n  font-size: 1.1rem;\n}\n\n.contact-cards {\n  display: flex;\n  flex-direction: column;\n  gap: 2rem;\n  margin-bottom: 4rem;\n}\n\n.contact-card {\n  background: white;\n  padding: 2.5rem;\n  border-radius: 16px;\n  display: flex;\n  gap: 1.5rem;\n  align-items: center;\n  box-shadow: 0 10px 30px rgba(74, 55, 45, 0.04);\n  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  opacity: 0;\n  transform: translateX(-30px);\n}\n\n.contact-card.is-visible {\n  opacity: 1; transform: translateX(0);\n}\n\n.contact-card:hover {\n  transform: translateY(-8px) scale(1.02);\n  box-shadow: 0 20px 50px rgba(74, 55, 45, 0.08);\n}\n\n.card-icon {\n  width: 65px;\n  height: 65px;\n  background: #fff5eb;\n  color: #efa962;\n  border-radius: 14px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1.8rem;\n  flex-shrink: 0;\n  transition: all 0.3s ease;\n}\n\n.contact-card:hover .card-icon {\n  background: #efa962;\n  color: white;\n  transform: rotate(10deg);\n}\n\n.card-body h3 {\n  font-size: 1.35rem;\n  margin-bottom: 0.5rem;\n  color: #3e2723;\n}\n\n.card-body p {\n  color: #8d6e63;\n  line-height: 1.6;\n}\n\n.social-box {\n  background: #3e2723;\n  padding: 2rem;\n  border-radius: 16px;\n  color: white;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  opacity: 0;\n  transform: scale(0.9);\n  transition: all 0.6s ease;\n}\n\n.social-box.is-visible {\n  opacity: 1; transform: scale(1);\n}\n\n.social-icons {\n  display: flex;\n  gap: 1.2rem;\n}\n\n.social-btn {\n  width: 48px;\n  height: 48px;\n  background: rgba(255,255,255,0.1);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  font-size: 1.25rem;\n  transition: all 0.3s ease;\n  text-decoration: none;\n}\n\n.social-btn:hover {\n  background: #efa962;\n  transform: translateY(-5px);\n}\n\n/* --- Form Column --- */\n.form-premium-card {\n  background: white;\n  padding: 4.5rem;\n  border-radius: 24px;\n  box-shadow: 0 40px 100px rgba(74, 55, 45, 0.07);\n  position: relative;\n  overflow: hidden;\n  opacity: 0;\n  transform: translateX(30px);\n  transition: all 1s ease;\n}\n\n.form-premium-card.is-visible {\n  opacity: 1; transform: translateX(0);\n}\n\n.form-premium-card::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; width: 6px; height: 100%;\n  background: #efa962;\n}\n\n.card-header {\n  margin-bottom: 3.5rem;\n  display: flex;\n  align-items: center;\n  gap: 1.2rem;\n}\n\n.card-header i { font-size: 2.5rem; color: #efa962; }\n.card-header h3 { font-family: 'Dancing Script', cursive; font-size: 2.8rem; color: #3e2723; }\n\n.input-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 2rem;\n}\n\n.input-group {\n  position: relative;\n  margin-bottom: 3rem;\n}\n\n.input-group input,\n.input-group textarea {\n  width: 100%;\n  padding: 12px 10px 10px 5px;\n  display: block;\n  border: none;\n  border-bottom: 2px solid #e0d5d0;\n  background: transparent;\n  font-size: 1.1rem;\n  color: #3e2723;\n  transition: all 0.3s ease;\n}\n\n.input-group input:focus,\n.input-group textarea:focus {\n  outline: none;\n}\n\n.input-group label {\n  color: #8d6e63;\n  font-size: 1.05rem;\n  font-weight: 500;\n  position: absolute;\n  pointer-events : none;\n  left: 5px;\n  top: 10px;\n  transition: all 0.3s ease;\n}\n\n.input-group input:focus ~ label,\n.input-group input:not(:placeholder-shown) ~ label,\n.input-group textarea:focus ~ label,\n.input-group textarea:not(:placeholder-shown) ~ label {\n  top: -20px;\n  font-size: 0.9rem;\n  color: #efa962;\n  font-weight: 700;\n}\n\n.bar {\n  position: relative;\n  display: block;\n  width: 100%;\n}\n\n.bar:before, .bar:after {\n  content: '';\n  height: 2px;\n  width: 0;\n  bottom: 0px;\n  position: absolute;\n  background: #efa962;\n  transition: all 0.3s ease;\n}\n\n.bar:before { left: 50%; }\n.bar:after { right: 50%; }\n\n.input-group input:focus ~ .bar:before, .input-group input:focus ~ .bar:after,\n.input-group textarea:focus ~ .bar:before, .input-group textarea:focus ~ .bar:after {\n  width: 50%;\n}\n\n.btn-premium {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 1.2rem;\n  width: 100%;\n  padding: 1.5rem;\n  background: #3e2723;\n  color: white;\n  border: none;\n  border-radius: 12px;\n  font-weight: 700;\n  font-size: 1.1rem;\n  cursor: pointer;\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  margin-top: 2rem;\n}\n\n.btn-premium:hover {\n  background: #efa962;\n  transform: translateY(-3px);\n  box-shadow: 0 15px 30px rgba(239, 169, 98, 0.3);\n}\n\n/* --- Map Immersive --- */\n.map-immersive {\n  padding-bottom: 10rem;\n}\n\n.map-frame {\n  display: flex;\n  background: white;\n  border-radius: 30px;\n  overflow: hidden;\n  box-shadow: 0 40px 100px rgba(74, 55, 45, 0.08);\n  opacity: 0;\n  transform: translateY(40px);\n  transition: all 1s ease;\n}\n\n.map-frame.is-visible {\n  opacity: 1; transform: translateY(0);\n}\n\n.map-inner {\n  flex: 1.5;\n  height: 500px;\n  position: relative;\n}\n\n.map-inner img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.map-marker-floating {\n  position: absolute;\n  top: 50%; left: 50%;\n  transform: translate(-50%, -100%);\n  z-index: 5;\n}\n\n.pin {\n  width: 30px; height: 30px;\n  border-radius: 50% 50% 50% 0;\n  background: #efa962;\n  transform: rotate(-45deg);\n  position: relative;\n  box-shadow: 0 10px 20px rgba(0,0,0,0.2);\n}\n\n.pin::after {\n  content: '';\n  width: 14px; height: 14px;\n  margin: 8px 0 0 8px;\n  background: #3e2723;\n  position: absolute;\n  border-radius: 50%;\n}\n\n.pulse {\n  background: rgba(239,169,98,0.5);\n  border-radius: 50%;\n  height: 40px; width: 40px;\n  position: absolute;\n  left: 50%; top: 50%;\n  transform: translate(-50%, -50%);\n  z-index: -2;\n  animation: pulsePin 2s infinite;\n}\n\n@keyframes pulsePin {\n  0% { transform: translate(-50%, -50%) scale(0.1); opacity: 0; }\n  50% { opacity: 0.6; }\n  100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }\n}\n\n.map-details {\n  flex: 1;\n  padding: 5rem;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  background: #fffdfc;\n}\n\n.map-details h2 { font-family: 'Dancing Script', cursive; font-size: 3rem; margin-bottom: 1.5rem; color: #3e2723; }\n.map-details p { font-size: 1.15rem; color: #8d6e63; margin-bottom: 2.5rem; line-height: 1.6; }\n\n.btn-link {\n  background: none; border: none;\n  font-size: 1.1rem; font-weight: 700;\n  color: #efa962; cursor: pointer;\n  display: flex; align-items: center; gap: 0.8rem;\n  padding: 0;\n  transition: all 0.3s ease;\n}\n\n.btn-link:hover { color: #3e2723; transform: translateX(5px); }\n\n@media (max-width: 1024px) {\n  .redesign-grid { grid-template-columns: 1fr; gap: 6rem; }\n  .map-frame { flex-direction: column; }\n  .map-inner { height: 400px; }\n  .map-details { padding: 3rem; text-align: center; align-items: center; }\n}\n\n@media (max-width: 768px) {\n  .form-premium-card { padding: 2rem; }\n  .input-row { grid-template-columns: 1fr; gap: 0; }\n  .page-title { font-size: 3.5rem; }\n  .main-contact { padding: 5rem 0; }\n}\n</style>\n"],"mappings":";;AAqIA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,SAAS,EAAE,EAAE;QACbC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE;MACX;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAAA,EAAG;MACXC,KAAK,CAAC,0DAA0D,CAAC;MACjE,IAAI,CAACR,IAAG,GAAI;QACVC,SAAS,EAAE,EAAE;QACbC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE;MACX,CAAC;IACH;EACF,CAAC;EACDI,UAAU,EAAE;IACVC,eAAe,EAAE;