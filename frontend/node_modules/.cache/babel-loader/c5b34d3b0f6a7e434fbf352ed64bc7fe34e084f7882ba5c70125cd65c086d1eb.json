{"ast":null,"code":"import axios from \"@/utils/axios\";\nimport socket from \"@/socket.js\";\nexport default {\n  name: \"WalletPage\",\n  data() {\n    return {\n      balance: 0,\n      addAmount: \"\",\n      loading: false\n    };\n  },\n  mounted() {\n    this.fetchBalance();\n\n    // Socket listeners for real-time updates\n    socket.on(\"walletUpdated\", data => {\n      this.balance = data.balance;\n    });\n  },\n  beforeUnmount() {\n    // Remove socket listeners\n    socket.off(\"walletUpdated\");\n  },\n  methods: {\n    async fetchBalance() {\n      try {\n        const res = await axios.get(\"/api/wallet/balance\");\n        if (res.data.success) {\n          this.balance = res.data.balance;\n        }\n      } catch (err) {\n        console.error(\"Error fetching balance:\", err);\n        alert(\"Failed to fetch wallet balance\");\n      }\n    },\n    setAmount(amount) {\n      this.addAmount = amount;\n    },\n    async addMoney() {\n      if (!this.addAmount || this.addAmount < 100 || this.addAmount > 1000) {\n        alert(\"Please enter an amount between ₹100 and ₹1000\");\n        return;\n      }\n      this.loading = true;\n      try {\n        // Create Razorpay order\n        const res = await axios.post(\"/api/wallet/add-money\", {\n          amount: this.addAmount\n        });\n        if (res.data.success) {\n          // Initialize Razorpay checkout\n          const options = {\n            key: res.data.key,\n            amount: res.data.amount,\n            currency: res.data.currency,\n            order_id: res.data.orderId,\n            name: \"Distribution Agency\",\n            description: \"Add Money to Wallet\",\n            handler: async response => {\n              // Verify payment\n              await this.verifyPayment(response, res.data.amount);\n            },\n            prefill: {\n              name: \"User\",\n              email: \"user@example.com\"\n            },\n            theme: {\n              color: \"#2874f0\"\n            }\n          };\n          const rzp = new window.Razorpay(options);\n          rzp.open();\n        }\n      } catch (err) {\n        console.error(\"Error creating payment order:\", err);\n        alert(\"Failed to initiate payment\");\n      } finally {\n        this.loading = false;\n      }\n    },\n    async verifyPayment(razorpayResponse, amount) {\n      try {\n        const res = await axios.post(\"/api/wallet/verify-payment\", {\n          razorpay_order_id: razorpayResponse.razorpay_order_id,\n          razorpay_payment_id: razorpayResponse.razorpay_payment_id,\n          razorpay_signature: razorpayResponse.razorpay_signature,\n          amount: amount\n        });\n        if (res.data.success) {\n          alert(\"Payment successful! Wallet updated.\");\n          this.balance = res.data.newBalance;\n          this.addAmount = \"\";\n        } else {\n          alert(\"Payment verification failed\");\n        }\n      } catch (err) {\n        console.error(\"Error verifying payment:\", err);\n        alert(\"Payment verification failed\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","socket","name","data","balance","addAmount","loading","mounted","fetchBalance","on","beforeUnmount","off","methods","res","get","success","err","console","error","alert","setAmount","amount","addMoney","post","options","key","currency","order_id","orderId","description","handler","response","verifyPayment","prefill","email","theme","color","rzp","window","Razorpay","open","razorpayResponse","razorpay_order_id","razorpay_payment_id","razorpay_signature","newBalance"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\WalletPage.vue"],"sourcesContent":["<template>\n  <div class=\"wallet-modal-overlay\" @click=\"$emit('close')\">\n    <div class=\"wallet-modal\" @click.stop>\n      <div class=\"modal-header\">\n        <h2>My Wallet</h2>\n        <button class=\"close-btn\" @click=\"$emit('close')\">✕</button>\n      </div>\n\n      <div class=\"modal-body\">\n        <!-- Wallet Balance -->\n        <div class=\"balance-section\">\n          <div class=\"balance-card\">\n            <h3>Current Balance</h3>\n            <div class=\"balance-amount\">\n              <span class=\"currency\">₹</span>\n              <span class=\"amount\">{{ balance }}</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- Add Money Section -->\n        <div class=\"add-money-section\">\n          <h3>Add Money to Wallet</h3>\n          <div class=\"add-money-form\">\n            <div class=\"amount-input-group\">\n              <label for=\"amount\">Enter Amount (₹)</label>\n              <input\n                type=\"number\"\n                id=\"amount\"\n                v-model=\"addAmount\"\n                placeholder=\"Enter amount\"\n                min=\"100\"\n                max=\"1000\"\n                :disabled=\"loading\"\n              />\n            </div>\n            <button\n              class=\"add-money-btn\"\n              @click=\"addMoney\"\n              :disabled=\"loading || !addAmount || addAmount < 100\"\n            >\n              {{ loading ? \"Processing...\" : \"Add Money\" }}\n            </button>\n          </div>\n        </div>\n\n        <!-- Quick Amount Buttons -->\n        <div class=\"quick-amounts\">\n          <p>Quick Add:</p>\n          <div class=\"amount-buttons\">\n            <button @click=\"setAmount(100)\" :disabled=\"loading\">₹100</button>\n            <button @click=\"setAmount(200)\" :disabled=\"loading\">₹200</button>\n            <button @click=\"setAmount(500)\" :disabled=\"loading\">₹500</button>\n            <button @click=\"setAmount(1000)\" :disabled=\"loading\">₹1000</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from \"@/utils/axios\";\nimport socket from \"@/socket.js\";\n\nexport default {\n  name: \"WalletPage\",\n  data() {\n    return {\n      balance: 0,\n      addAmount: \"\",\n      loading: false,\n    };\n  },\n  mounted() {\n    this.fetchBalance();\n\n    // Socket listeners for real-time updates\n    socket.on(\"walletUpdated\", (data) => {\n      this.balance = data.balance;\n    });\n  },\n  beforeUnmount() {\n    // Remove socket listeners\n    socket.off(\"walletUpdated\");\n  },\n  methods: {\n    async fetchBalance() {\n      try {\n        const res = await axios.get(\"/api/wallet/balance\");\n        if (res.data.success) {\n          this.balance = res.data.balance;\n        }\n      } catch (err) {\n        console.error(\"Error fetching balance:\", err);\n        alert(\"Failed to fetch wallet balance\");\n      }\n    },\n\n    setAmount(amount) {\n      this.addAmount = amount;\n    },\n\n    async addMoney() {\n      if (!this.addAmount || this.addAmount < 100 || this.addAmount > 1000) {\n        alert(\"Please enter an amount between ₹100 and ₹1000\");\n        return;\n      }\n\n      this.loading = true;\n      try {\n        // Create Razorpay order\n        const res = await axios.post(\"/api/wallet/add-money\", {\n          amount: this.addAmount,\n        });\n\n        if (res.data.success) {\n          // Initialize Razorpay checkout\n          const options = {\n            key: res.data.key,\n            amount: res.data.amount,\n            currency: res.data.currency,\n            order_id: res.data.orderId,\n            name: \"Distribution Agency\",\n            description: \"Add Money to Wallet\",\n            handler: async (response) => {\n              // Verify payment\n              await this.verifyPayment(response, res.data.amount);\n            },\n            prefill: {\n              name: \"User\",\n              email: \"user@example.com\",\n            },\n            theme: {\n              color: \"#2874f0\",\n            },\n          };\n\n          const rzp = new window.Razorpay(options);\n          rzp.open();\n        }\n      } catch (err) {\n        console.error(\"Error creating payment order:\", err);\n        alert(\"Failed to initiate payment\");\n      } finally {\n        this.loading = false;\n      }\n    },\n\n    async verifyPayment(razorpayResponse, amount) {\n      try {\n        const res = await axios.post(\"/api/wallet/verify-payment\", {\n          razorpay_order_id: razorpayResponse.razorpay_order_id,\n          razorpay_payment_id: razorpayResponse.razorpay_payment_id,\n          razorpay_signature: razorpayResponse.razorpay_signature,\n          amount: amount,\n        });\n\n        if (res.data.success) {\n          alert(\"Payment successful! Wallet updated.\");\n          this.balance = res.data.newBalance;\n          this.addAmount = \"\";\n        } else {\n          alert(\"Payment verification failed\");\n        }\n      } catch (err) {\n        console.error(\"Error verifying payment:\", err);\n        alert(\"Payment verification failed\");\n      }\n    },\n  },\n};\n</script>\n\n<style scoped>\n.wallet-modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background-color: rgba(0, 0, 0, 0.5);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 1000;\n}\n\n.wallet-modal {\n  background: white;\n  border-radius: 8px;\n  width: 90%;\n  max-width: 500px;\n  max-height: 80vh;\n  overflow-y: auto;\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);\n}\n\n.modal-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 20px;\n  border-bottom: 1px solid #e0e0e0;\n}\n\n.modal-header h2 {\n  margin: 0;\n  color: #333;\n}\n\n.close-btn {\n  background: none;\n  border: none;\n  font-size: 24px;\n  cursor: pointer;\n  color: #666;\n  padding: 0;\n  width: 30px;\n  height: 30px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.close-btn:hover {\n  color: #333;\n}\n\n.modal-body {\n  padding: 20px;\n}\n\n.balance-section {\n  margin-bottom: 30px;\n}\n\n.balance-card {\n  background: linear-gradient(135deg, #2874f0, #5ba2f4);\n  color: white;\n  padding: 20px;\n  border-radius: 8px;\n  text-align: center;\n}\n\n.balance-card h3 {\n  margin: 0 0 10px 0;\n  font-size: 16px;\n  font-weight: 500;\n}\n\n.balance-amount {\n  display: flex;\n  align-items: baseline;\n  justify-content: center;\n  font-size: 32px;\n  font-weight: bold;\n}\n\n.currency {\n  font-size: 24px;\n  margin-right: 4px;\n}\n\n.add-money-section h3 {\n  margin: 0 0 15px 0;\n  color: #333;\n  font-size: 18px;\n}\n\n.add-money-form {\n  display: flex;\n  gap: 10px;\n  margin-bottom: 20px;\n}\n\n.amount-input-group {\n  flex: 1;\n}\n\n.amount-input-group label {\n  display: block;\n  margin-bottom: 5px;\n  font-weight: 500;\n  color: #555;\n}\n\n.amount-input-group input {\n  width: 100%;\n  padding: 10px;\n  border: 1px solid #ddd;\n  border-radius: 4px;\n  font-size: 16px;\n}\n\n.amount-input-group input:disabled {\n  background-color: #f5f5f5;\n  cursor: not-allowed;\n}\n\n.add-money-btn {\n  background-color: #ff9f00;\n  color: white;\n  border: none;\n  padding: 10px 20px;\n  border-radius: 4px;\n  font-weight: bold;\n  cursor: pointer;\n  transition: background-color 0.2s;\n  white-space: nowrap;\n}\n\n.add-money-btn:hover:not(:disabled) {\n  background-color: #f39400;\n}\n\n.add-money-btn:disabled {\n  background-color: #ccc;\n  cursor: not-allowed;\n}\n\n.quick-amounts {\n  border-top: 1px solid #e0e0e0;\n  padding-top: 20px;\n}\n\n.quick-amounts p {\n  margin: 0 0 10px 0;\n  font-weight: 500;\n  color: #555;\n}\n\n.amount-buttons {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n}\n\n.amount-buttons button {\n  background: white;\n  border: 1px solid #2874f0;\n  color: #2874f0;\n  padding: 8px 16px;\n  border-radius: 4px;\n  cursor: pointer;\n  font-weight: 500;\n  transition: all 0.2s;\n}\n\n.amount-buttons button:hover:not(:disabled) {\n  background-color: #2874f0;\n  color: white;\n}\n\n.amount-buttons button:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n@media (max-width: 480px) {\n  .wallet-modal {\n    width: 95%;\n    margin: 20px;\n  }\n\n  .add-money-form {\n    flex-direction: column;\n  }\n\n  .add-money-btn {\n    width: 100%;\n  }\n\n  .amount-buttons {\n    justify-content: center;\n  }\n}\n</style>\n"],"mappings":"AA8DA,OAAOA,KAAI,MAAO,eAAe;AACjC,OAAOC,MAAK,MAAO,aAAa;AAEhC,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,CAAC;MACVC,SAAS,EAAE,EAAE;MACbC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,YAAY,CAAC,CAAC;;IAEnB;IACAP,MAAM,CAACQ,EAAE,CAAC,eAAe,EAAGN,IAAI,IAAK;MACnC,IAAI,CAACC,OAAM,GAAID,IAAI,CAACC,OAAO;IAC7B,CAAC,CAAC;EACJ,CAAC;EACDM,aAAaA,CAAA,EAAG;IACd;IACAT,MAAM,CAACU,GAAG,CAAC,eAAe,CAAC;EAC7B,CAAC;EACDC,OAAO,EAAE;IACP,MAAMJ,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMK,GAAE,GAAI,MAAMb,KAAK,CAACc,GAAG,CAAC,qBAAqB,CAAC;QAClD,IAAID,GAAG,CAACV,IAAI,CAACY,OAAO,EAAE;UACpB,IAAI,CAACX,OAAM,GAAIS,GAAG,CAACV,IAAI,CAACC,OAAO;QACjC;MACF,EAAE,OAAOY,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,yBAAyB,EAAEF,GAAG,CAAC;QAC7CG,KAAK,CAAC,gCAAgC,CAAC;MACzC;IACF,CAAC;IAEDC,SAASA,CAACC,MAAM,EAAE;MAChB,IAAI,CAAChB,SAAQ,GAAIgB,MAAM;IACzB,CAAC;IAED,MAAMC,QAAQA,CAAA,EAAG;MACf,IAAI,CAAC,IAAI,CAACjB,SAAQ,IAAK,IAAI,CAACA,SAAQ,GAAI,GAAE,IAAK,IAAI,CAACA,SAAQ,GAAI,IAAI,EAAE;QACpEc,KAAK,CAAC,+CAA+C,CAAC;QACtD;MACF;MAEA,IAAI,CAACb,OAAM,GAAI,IAAI;MACnB,IAAI;QACF;QACA,MAAMO,GAAE,GAAI,MAAMb,KAAK,CAACuB,IAAI,CAAC,uBAAuB,EAAE;UACpDF,MAAM,EAAE,IAAI,CAAChB;QACf,CAAC,CAAC;QAEF,IAAIQ,GAAG,CAACV,IAAI,CAACY,OAAO,EAAE;UACpB;UACA,MAAMS,OAAM,GAAI;YACdC,GAAG,EAAEZ,GAAG,CAACV,IAAI,CAACsB,GAAG;YACjBJ,MAAM,EAAER,GAAG,CAACV,IAAI,CAACkB,MAAM;YACvBK,QAAQ,EAAEb,GAAG,CAACV,IAAI,CAACuB,QAAQ;YAC3BC,QAAQ,EAAEd,GAAG,CAACV,IAAI,CAACyB,OAAO;YAC1B1B,IAAI,EAAE,qBAAqB;YAC3B2B,WAAW,EAAE,qBAAqB;YAClCC,OAAO,EAAE,MAAOC,QAAQ,IAAK;cAC3B;cACA,MAAM,IAAI,CAACC,aAAa,CAACD,QAAQ,EAAElB,GAAG,CAACV,IAAI,CAACkB,MAAM,CAAC;YACrD,CAAC;YACDY,OAAO,EAAE;cACP/B,I