ntVNode","_createElementVNode","_hoisted_2","_hoisted_3","_Fragment","_renderList","n","key","style","_normalizeStyle","$options","getParticleStyle","_hoisted_4","_hoisted_5","_normalizeClass","$data","animate","onClick","_cache","args","scrollToProducts","xmlns","viewBox","fill","d","scrollToAbout","stats","stat","index","_hoisted_6","_toDisplayString","number","_hoisted_7","label","_hoisted_8","_hoisted_9","_hoisted_10","_hoisted_11","categories","cat","transitionDelay","_hoisted_12","_hoisted_13","icon","_hoisted_14","name","_hoisted_15","_hoisted_16","_hoisted_17","_hoisted_18","_hoisted_19","features","feature","i","_hoisted_20","_hoisted_21","title","_hoisted_22","desc","_hoisted_23","_hoisted_24","_hoisted_25","_hoisted_26","_hoisted_27","values","val","_hoisted_28","_hoisted_29","_hoisted_30","text","_hoisted_31","_hoisted_32","_hoisted_33","_hoisted_34","testimonials","testim","_hoisted_35","_hoisted_36","_hoisted_37","initials","_hoisted_38","_hoisted_39","_hoisted_40","role","_hoisted_41","_hoisted_42","_hoisted_43","_hoisted_44"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\Home.vue"],"sourcesContent":["<template>\n  <div class=\"home-page\">\n    <!-- Hero Section -->\n    <section class=\"hero\">\n      <div class=\"hero-bg-overlay\"></div>\n      <div class=\"hero-particles\">\n        <div v-for=\"n in 20\" :key=\"n\" class=\"particle\" :style=\"getParticleStyle(n)\"></div>\n      </div>\n      \n      <div class=\"hero-content container\">\n        <div class=\"hero-text-wrapper\">\n          <div class=\"hero-badge\" :class=\"{ 'fade-in': animate }\">\n            <span class=\"badge-icon\">👑</span>\n            <span class=\"badge-text\">Kerala's Premier Distribution Partner</span>\n          </div>\n          \n          <h1 class=\"hero-title\" :class=\"{ 'slide-up': animate }\">\n            Elevating <span class=\"gradient-text\">Baking Excellence</span>\n          </h1>\n          \n          <p class=\"hero-subtitle\" :class=\"{ 'slide-up-delay': animate }\">\n            Supplying premium ingredients and equipment to passionate bakers and commercial kitchens since 2020.\n          </p>\n          \n          <div class=\"hero-cta-group\" :class=\"{ 'fade-in-delay': animate }\">\n            <button class=\"btn-primary\" @click=\"scrollToProducts\">\n              <span>View Catalog</span>\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"btn-icon\" viewBox=\"0 0 20 20\" fill=\"currentColor\">\n                <path fill-rule=\"evenodd\" d=\"M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z\" clip-rule=\"evenodd\" />\n              </svg>\n            </button>\n            <button class=\"btn-secondary\" @click=\"scrollToAbout\">\n              <span>Our Story</span>\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- Floating Stats Bar -->\n      <div class=\"stats-bar container\" :class=\"{ 'slide-up-late': animate }\">\n        <div v-for=\"(stat, index) in stats\" :key=\"index\" class=\"stat-item\">\n          <div class=\"stat-number\">{{ stat.number }}</div>\n          <div class=\"stat-label\">{{ stat.label }}</div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Featured Categories Section -->\n    <section class=\"section categories-section\">\n      <div class=\"container\">\n        <div class=\"section-header text-center\" v-animate-on-scroll>\n          <span class=\"section-badge\">Our Selection</span>\n          <h2 class=\"section-title\">Premium Categories</h2>\n          <p class=\"section-desc\">Everything you need to create your masterpiece</p>\n        </div>\n\n        <div class=\"categories-grid\">\n          <div v-for=\"(cat, index) in categories\" :key=\"index\" class=\"category-card\" v-animate-on-scroll :style=\"{ transitionDelay: `${index * 100}ms` }\">\n            <div class=\"category-bg\" :style=\"cat.style\"></div>\n            <div class=\"category-content\">\n              <span class=\"category-icon\">{{ cat.icon }}</span>\n              <h3 class=\"category-name\">{{ cat.name }}</h3>\n              <button class=\"btn-link\">Explore →</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- About Section -->\n    <section id=\"about\" class=\"section about-section\">\n      <div class=\"container\">\n        <div class=\"about-grid\">\n          <div class=\"about-content\" v-animate-on-scroll>\n            <span class=\"section-badge\">Who We Are</span>\n            <h2 class=\"section-title\">Passion for Quality,<br>Dedication to Service</h2>\n            <p class=\"about-text\">\n              At Cochin Distributors, we see ourselves as more than just suppliers; we are partners in your baking journey. \n              Founded in 2020, we have grown to become Kerala's most trusted source for professional baking supplies.\n            </p>\n            <div class=\"feature-list\">\n              <div v-for=\"(feature, i) in features\" :key=\"i\" class=\"feature-item\">\n                <div class=\"feature-icon-box\">{{ feature.icon }}</div>\n                <div>\n                  <h4 class=\"feature-title-sm\">{{ feature.title }}</h4>\n                  <p class=\"feature-desc-sm\">{{ feature.desc }}</p>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"about-visual\" v-animate-on-scroll>\n            <div class=\"visual-card main-card\">\n              <div class=\"card-gradient gradient-blue\"></div>\n              <span class=\"visual-icon\">🏭</span>\n              <span>Large Scale Warehousing</span>\n            </div>\n            <div class=\"visual-card float-card\">\n              <div class=\"card-gradient gradient-gold\"></div>\n              <div class=\"rating-box\">\n                <span class=\"stars\">⭐⭐⭐⭐⭐</span>\n                <span class=\"rating-text\">Top Rated Service</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Why Choose Us -->\n    <section class=\"section why-us-section\">\n      <div class=\"container\">\n        <div class=\"section-header text-center\" v-animate-on-scroll>\n          <span class=\"section-badge\">Why Choose Us</span>\n          <h2 class=\"section-title\">The Cochin Advantage</h2>\n        </div>\n        \n        <div class=\"values-grid\">\n          <div v-for=\"(val, i) in values\" :key=\"i\" class=\"value-card\" v-animate-on-scroll>\n            <div class=\"value-icon-wrapper\">{{ val.icon }}</div>\n            <h3 class=\"value-title\">{{ val.title }}</h3>\n            <p class=\"value-text\">{{ val.text }}</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Testimonials -->\n    <section class=\"section testimonials-section\">\n      <div class=\"container\">\n        <div class=\"section-header text-center\" v-animate-on-scroll>\n          <span class=\"section-badge\">Testimonials</span>\n          <h2 class=\"section-title\">Trusted by the Best</h2>\n        </div>\n        \n        <div class=\"testimonials-grid\">\n          <div v-for=\"(testim, i) in testimonials\" :key=\"i\" class=\"testimonial-card\" v-animate-on-scroll>\n            <div class=\"quote-icon\">\"</div>\n            <p class=\"testimonial-text\">{{ testim.text }}</p>\n            <div class=\"testimonial-author\">\n              <div class=\"author-avatar\">{{ testim.initials }}</div>\n              <div class=\"author-info\">\n                <h4 class=\"author-name\">{{ testim.name }}</h4>\n                <span class=\"author-role\">{{ testim.role }}</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Newsletter / CTA -->\n    <section class=\"section newsletter-section\">\n      <div class=\"container\">\n        <div class=\"newsletter-box\" v-animate-on-scroll>\n          <div class=\"newsletter-content\">\n            <h2 class=\"newsletter-title\">Ready to Elevate Your Baking?</h2>\n            <p class=\"newsletter-desc\">Join our network and get access to exclusive products and wholesale prices.</p>\n          </div>\n          <div class=\"newsletter-action\">\n            <button class=\"btn-primary btn-large\" @click=\"scrollToProducts\">Get Started Now</button>\n          </div>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"HomePage\",\n  data() {\n    return {\n      animate: false,\n      stats: [\n        { number: \"500+\", label: \"Premium Products\" },\n        { number: \"1k+\", label: \"Happy Partners\" },\n        { number: \"24/7\", label: \"Expert Support\" },\n        { number: \"100%\", label: \"Quality Guarantee\" },\n      ],\n      categories: [\n        { name: \"Bakery Fats & Margarines\", icon: \"🧈\", style: { background: \"linear-gradient(135deg, #FFEFBA 0%, #FFFFFF 100%)\" } },\n        { name: \"Chocolates & Fillings\", icon: \"🍫\", style: { background: \"linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%)\" } },\n        { name: \"Yeast & Improvers\", icon: \"🍞\", style: { background: \"linear-gradient(135deg, #cfd9df 0%, #e2ebf0 100%)\" } },\n        { name: \"Cake Premixes\", icon: \"🎂\", style: { background: \"linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%)\" } },\n      ],\n      features: [\n        { icon: \"⚡\", title: \"Fast Delivery\", desc: \"Same-day dispatch for orders within city limits.\" },\n        { icon: \"🛡️\", title: \"Quality Assured\", desc: \"Every product is vetted for professional standards.\" },\n        { icon: \"💰\", title: \"Wholesale Pricing\", desc: \"Competitive rates designed for business growth.\" },\n      ],\n      values: [\n        { icon: \"🤝\", title: \"Reliability\", text: \"We deliver