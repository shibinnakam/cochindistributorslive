{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"AboutPage\",\n  data() {\n    return {\n      email: \"\"\n    };\n  },\n  methods: {\n    subscribe() {\n      alert(\"Thank you for subscribing!\");\n      this.email = \"\";\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver(entries => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, {\n          threshold: 0.1\n        });\n        observer.observe(el);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","email","methods","subscribe","alert","directives","animateOnScroll","mounted","el","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","classList","add","unobserve","threshold","observe"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\About.vue"],"sourcesContent":["<template>\n  <div class=\"about-page\">\n    <!-- Header Section -->\n    <section class=\"about-header\">\n      <div class=\"header-overlay\"></div>\n      <h1 class=\"page-title\">About Us</h1>\n    </section>\n\n    <!-- Our Story Section -->\n    <section class=\"our-story container\">\n      <div class=\"story-grid\">\n        <div class=\"story-image\" v-animate-on-scroll>\n          <img src=\"https://images.unsplash.com/photo-1583394202118-028302f37e44?auto=format&fit=crop&q=80&w=800\" alt=\"Our Chef\" class=\"chef-img\" />\n        </div>\n        <div class=\"story-content\" v-animate-on-scroll>\n          <h2 class=\"section-title\">Our Story</h2>\n          <p class=\"story-text\">\n            We began our journey with a passion for good, homemade food. Our founder started this bakery to share his love of bread, cakes, pastries and other baked goodness with the world. Supported by our local farmers and suppliers, we have started this bakery to bring people together from far and wide with the love of freshly made food that tastes like home.\n          </p>\n          <p class=\"story-text\">\n            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo sed diam voluptua.\n          </p>\n          <div class=\"founder-info\">\n            <h4 class=\"founder-name\">Adam Smith</h4>\n            <p class=\"founder-role\">Owner, Bready Bake</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Testimonial Section -->\n    <section class=\"testimonial-section\">\n      <div class=\"testimonial-bg\">\n        <img src=\"https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&q=80&w=1200\" alt=\"Baking session\" class=\"bg-img\" />\n        <div class=\"bg-overlay\"></div>\n      </div>\n      <div class=\"testimonial-content container\" v-animate-on-scroll>\n        <h2 class=\"testimonial-header\">Hear From Our Customers</h2>\n        <p class=\"testimonial-subheader\">Don't just take our word for it. Hear what our customers have to say about our bakery.</p>\n        \n        <div class=\"testimonial-card\">\n          <p class=\"quote\">\n            \"Absolutely loved it! They were amazing and I was completely satisfied with them. Would definitely recommend to all my friends and family\"\n          </p>\n          <div class=\"customer-info\">\n            <img src=\"https://i.pravatar.cc/100?u=logan\" alt=\"Logan May\" class=\"customer-avatar\" />\n            <h4 class=\"customer-name\">Logan May</h4>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Newsletter Section -->\n    <section class=\"newsletter-section\">\n      <div class=\"container\">\n        <h2 class=\"newsletter-title\">Subscribe To Our Newsletter</h2>\n        <form class=\"newsletter-form\" @submit.prevent=\"subscribe\">\n          <input type=\"email\" placeholder=\"your email address\" required v-model=\"email\" />\n          <button type=\"submit\" class=\"btn-subscribe\">Subscribe</button>\n        </form>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"AboutPage\",\n  data() {\n    return {\n      email: \"\"\n    };\n  },\n  methods: {\n    subscribe() {\n      alert(\"Thank you for subscribing!\");\n      this.email = \"\";\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver((entries) => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, { threshold: 0.1 });\n        observer.observe(el);\n      }\n    }\n  }\n};\n</script>\n\n<style scoped>\n.about-page {\n  font-family: 'Plus Jakarta Sans', sans-serif;\n  color: #5d4037;\n  background-color: #ffffff;\n  padding-top: 80px;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 2rem;\n}\n\n/* --- Header --- */\n.about-header {\n  height: 300px;\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: url('https://images.unsplash.com/photo-1517433670267-08bbd4be890f?auto=format&fit=crop&q=80&w=1200') center/cover no-repeat;\n}\n\n.header-overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(255, 255, 255, 0.4);\n}\n\n.page-title {\n  position: relative;\n  z-index: 1;\n  font-family: 'Dancing Script', cursive;\n  font-size: 4.5rem;\n  color: #3e2723;\n  font-weight: 700;\n}\n\n/* --- Our Story --- */\n.our-story {\n  padding: 8rem 0;\n}\n\n.story-grid {\n  display: flex;\n  align-items: center;\n  gap: 5rem;\n}\n\n.story-image {\n  flex: 1;\n  opacity: 0;\n  transform: translateX(-30px);\n  transition: all 0.8s ease;\n}\n\n.story-image.is-visible {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n.chef-img {\n  width: 100%;\n  border-radius: 15px;\n  box-shadow: 20px 20px 50px rgba(0,0,0,0.05);\n}\n\n.story-content {\n  flex: 1.2;\n  opacity: 0;\n  transform: translateX(30px);\n  transition: all 0.8s ease 0.2s;\n}\n\n.story-content.is-visible {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n.section-title {\n  font-family: 'Dancing Script', cursive;\n  font-size: 3.5rem;\n  margin-bottom: 2rem;\n  color: #3e2723;\n}\n\n.story-text {\n  font-size: 1.05rem;\n  line-height: 1.8;\n  color: #8d6e63;\n  margin-bottom: 2rem;\n}\n\n.founder-info {\n  margin-top: 3rem;\n}\n\n.founder-name {\n  font-size: 1.4rem;\n  font-weight: 700;\n  color: #3e2723;\n  margin-bottom: 0.2rem;\n}\n\n.founder-role {\n  color: #efa962;\n  font-weight: 600;\n  font-size: 0.9rem;\n}\n\n/* --- Testimonial --- */\n.testimonial-section {\n  position: relative;\n  padding: 10rem 0;\n  min-height: 500px;\n  display: flex;\n  align-items: center;\n  overflow: hidden;\n}\n\n.testimonial-bg {\n  position: absolute;\n  inset: 0;\n  z-index: 0;\n}\n\n.bg-img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.bg-overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.4);\n}\n\n.testimonial-content {\n  position: relative;\n  z-index: 1;\n  text-align: center;\n  color: white;\n}\n\n.testimonial-header {\n  font-family: 'Dancing Script', cursive;\n  font-size: 3.8rem;\n  margin-bottom: 1rem;\n}\n\n.testimonial-subheader {\n  font-size: 1.1rem;\n  margin-bottom: 4rem;\n  opacity: 0.9;\n  max-width: 600px;\n  margin-left: auto;\n  margin-right: auto;\n}\n\n.testimonial-card {\n  background: white;\n  padding: 4rem 3rem;\n  max-width: 650px;\n  margin: 0 auto;\n  border-radius: 10px;\n  color: #5d4037;\n  box-shadow: 0 15px 40px rgba(0,0,0,0.2);\n}\n\n.quote {\n  font-size: 1.2rem;\n  line-height: 1.8;\n  font-style: italic;\n  margin-bottom: 2.5rem;\n}\n\n.customer-info {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n}\n\n.customer-avatar {\n  width: 70px;\n  height: 70px;\n  border-radius: 50%;\n  border: 3px solid #efa962;\n}\n\n.customer-name {\n  font-weight: 700;\n  font-size: 1.1rem;\n}\n\n/* --- Newsletter --- */\n.newsletter-section {\n  background-color: #3e2723;\n  padding: 6rem 0;\n  text-align: center;\n  color: white;\n}\n\n.newsletter-title {\n  font-family: 'Dancing Script', cursive;\n  font-size: 3.2rem;\n  margin-bottom: 3.5rem;\n}\n\n.newsletter-form {\n  display: flex;\n  justify-content: center;\n  gap: 1rem;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n.newsletter-form input {\n  flex: 1;\n  padding: 1.1rem 1.5rem;\n  border-radius: 4px;\n  border: 1px solid #5d4037;\n  background: #2b1b17;\n  color: white;\n  font-size: 1rem;\n}\n\n.btn-subscribe {\n  background-color: #efa962;\n  color: white;\n  border: none;\n  padding: 1.1rem 2.5rem;\n  border-radius: 4px;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.btn-subscribe:hover {\n  background-color: #e69642;\n  transform: translateY(-2px);\n}\n\n@media (max-width: 992px) {\n  .story-grid {\n    flex-direction: column;\n    text-align: center;\n  }\n  .story-content { transform: translateX(0); }\n  .page-title { font-size: 3.5rem; }\n  .testimonial-header { font-size: 2.8rem; }\n}\n\n@media (max-width: 768px) {\n  .newsletter-form {\n    flex-direction: column;\n  }\n}\n</style>\n"],"mappings":";;AAkEA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,SAASA,CAAA,EAAG;MACVC,KAAK,CAAC,4BAA4B,CAAC;MACnC,IAAI,CAACH,KAAI,GAAI,EAAE;IACjB;EACF,CAAC;EACDI,UAAU,EAAE;IACVC,eAAe,EAAE;MACfC,OAAOA,CAACC,EAAE,EAAE;QACV,MAAMC,QAAO,GAAI,IAAIC,oBAAoB,CAAEC,OAAO,IAAK;UACrDA,OAAO,CAACC,OAAO,CAACC,KAAI,IAAK;YACvB,IAAIA,KAAK,CAACC,cAAc,EAAE;cACxBN,EAAE,CAACO,SAAS,CAACC,GAAG,CAAC,YAAY,CAAC;cAC9BP,QAAQ,CAACQ,SAAS,CAACT,EAAE,CAAC;YACxB;UACF,CAAC,CAAC;QACJ,CAAC,EAAE;UAAEU,SAAS,EAAE;QAAI,CAAC,CAAC;QACtBT,QAAQ,CAACU,OAAO,CAACX,EAAE,CAAC;MACtB;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}