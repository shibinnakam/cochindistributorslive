{"ast":null,"code":"import Navbar from \"@/components/AppNavbar.vue\";\nimport LoginModal from \"@/views/Login.vue\"; // reuse your existing login.vue\n\nexport default {\n  name: \"App\",\n  components: {\n    Navbar,\n    LoginModal\n  },\n  data() {\n    return {\n      showLogin: false\n    };\n  },\n  async created() {\n    const token = localStorage.getItem(\"token\");\n    if (token) {\n      try {\n        // Verify token with backend\n        const res = await axios.get(\"/api/auth/verify\");\n        if (res.data.valid) {\n          // Sync user info just in case\n          localStorage.setItem(\"user\", JSON.stringify(res.data.user));\n        }\n      } catch (err) {\n        console.warn(\"Session verification failed on startup:\", err);\n        // We don't necessarily logout here, let the interceptor handle 401s\n      }\n    }\n  },\n  computed: {\n    isDashboard() {\n      // Hide navbar if route starts with /admin, /staff, or is /user\n      return this.$route.path.startsWith(\"/admin\") || this.$route.path.startsWith(\"/staff\") || this.$route.path === \"/user\";\n    }\n  }\n};","map":{"version":3,"names":["Navbar","LoginModal","name","components","data","showLogin","created","token","localStorage","getItem","res","axios","get","valid","setItem","JSON","stringify","user","err","console","warn","computed","isDashboard","$route","path","startsWith"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- Navbar only visible when NOT on /admin or /staff -->\n    <Navbar v-if=\"!isDashboard\" @open-login=\"showLogin = true\" />\n\n    <!-- Page Content -->\n    <router-view />\n\n    <!-- Login Modal -->\n    <LoginModal v-if=\"showLogin\" @close=\"showLogin = false\" />\n  </div>\n</template>\n\n<script>\nimport Navbar from \"@/components/AppNavbar.vue\";\nimport LoginModal from \"@/views/Login.vue\"; // reuse your existing login.vue\n\nexport default {\n  name: \"App\",\n  components: { Navbar, LoginModal },\n  data() {\n    return {\n      showLogin: false,\n    };\n  },\n  async created() {\n    const token = localStorage.getItem(\"token\");\n    if (token) {\n      try {\n        // Verify token with backend\n        const res = await axios.get(\"/api/auth/verify\");\n        if (res.data.valid) {\n          // Sync user info just in case\n          localStorage.setItem(\"user\", JSON.stringify(res.data.user));\n        }\n      } catch (err) {\n        console.warn(\"Session verification failed on startup:\", err);\n        // We don't necessarily logout here, let the interceptor handle 401s\n      }\n    }\n  },\n  computed: {\n    isDashboard() {\n      // Hide navbar if route starts with /admin, /staff, or is /user\n      return (\n        this.$route.path.startsWith(\"/admin\") ||\n        this.$route.path.startsWith(\"/staff\") ||\n        this.$route.path === \"/user\"\n      );\n    },\n  },\n};\n</script>\n"],"mappings":"AAcA,OAAOA,MAAK,MAAO,4BAA4B;AAC/C,OAAOC,UAAS,MAAO,mBAAmB,EAAE;;AAE5C,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IAAEH,MAAM;IAAEC;EAAW,CAAC;EAClCG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAMC,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;IAC3C,IAAIF,KAAK,EAAE;MACT,IAAI;QACF;QACA,MAAMG,GAAE,GAAI,MAAMC,KAAK,CAACC,GAAG,CAAC,kBAAkB,CAAC;QAC/C,IAAIF,GAAG,CAACN,IAAI,CAACS,KAAK,EAAE;UAClB;UACAL,YAAY,CAACM,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAACN,GAAG,CAACN,IAAI,CAACa,IAAI,CAAC,CAAC;QAC7D;MACF,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,IAAI,CAAC,yCAAyC,EAAEF,GAAG,CAAC;QAC5D;MACF;IACF;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,WAAWA,CAAA,EAAG;MACZ;MACA,OACE,IAAI,CAACC,MAAM,CAACC,IAAI,CAACC,UAAU,CAAC,QAAQ,KACpC,IAAI,CAACF,MAAM,CAACC,IAAI,CAACC,UAAU,CAAC,QAAQ,KACpC,IAAI,CAACF,MAAM,CAACC,IAAG,KAAM,OAAM;IAE/B;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}