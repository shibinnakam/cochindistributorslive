{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport axios from \"@/utils/axios\";\nexport default {\n  name: \"ProductEdit\",\n  props: {\n    productId: {\n      type: String,\n      required: true\n    }\n  },\n  data() {\n    return {\n      form: {\n        name: \"\",\n        description: \"\",\n        originalPrice: null,\n        discountPrice: null,\n        costPrice: null,\n        quantity: null,\n        image: \"\",\n        model3D: \"\",\n        shape: \"box\"\n      },\n      imageFile: null,\n      model3DFile: null,\n      newImagePreview: null,\n      loading: false\n    };\n  },\n  async mounted() {\n    await this.fetchProduct();\n  },\n  methods: {\n    getImageUrl(path) {\n      return path.startsWith(\"/\") ? path : path;\n    },\n    async fetchProduct() {\n      try {\n        const res = await axios.get(`/api/products/getproduct/${this.productId}`);\n        if (res.data.success) {\n          const product = res.data.product;\n          this.form = {\n            name: product.name,\n            description: product.description,\n            originalPrice: product.originalPrice,\n            discountPrice: product.discountPrice,\n            costPrice: product.costPrice,\n            quantity: product.quantity,\n            image: product.image || \"\",\n            model3D: product.model3D || \"\",\n            shape: product.shape || \"box\"\n          };\n        }\n      } catch (err) {\n        console.error(\"Error fetching product:\", err.response?.data || err.message);\n      }\n    },\n    handleFileUpload(e) {\n      this.imageFile = e.target.files[0];\n      if (this.imageFile) {\n        const reader = new FileReader();\n        reader.onload = event => {\n          this.newImagePreview = event.target.result;\n        };\n        reader.readAsDataURL(this.imageFile);\n      }\n    },\n    handleModelUpload(e) {\n      this.model3DFile = e.target.files[0];\n    },\n    async updateProduct() {\n      this.loading = true;\n      try {\n        const formData = new FormData();\n        Object.keys(this.form).forEach(key => {\n          if (this.form[key] !== null && this.form[key] !== \"\") {\n            if (key !== \"image\" && key !== \"model3D\") {\n              formData.append(key, this.form[key]);\n            }\n          }\n        });\n        if (this.imageFile) {\n          formData.append(\"image\", this.imageFile);\n        }\n        if (this.model3DFile) {\n          formData.append(\"model3D\", this.model3DFile);\n        }\n        const res = await axios.put(`/api/products/updateproduct/${this.productId}`, formData, {\n          headers: {\n            \"Content-Type\": \"multipart/form-data\"\n          }\n        });\n        if (res.data.success) {\n          this.$emit(\"updated\");\n        }\n      } catch (err) {\n        console.error(err.response?.data || err.message);\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","props","productId","type","String","required","data","form","description","originalPrice","discountPrice","costPrice","quantity","image","model3D","shape","imageFile","model3DFile","newImagePreview","loading","mounted","fetchProduct","methods","getImageUrl","path","startsWith","res","get","success","product","err","console","error","response","message","handleFileUpload","e","target","files","reader","FileReader","onload","event","result","readAsDataURL","handleModelUpload","updateProduct","formData","FormData","Object","keys","forEach","key","append","put","headers","$emit"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\ProductEdit.vue"],"sourcesContent":["<template>\n  <div class=\"form-wrapper\">\n    <div class=\"form-card\">\n      <h2 class=\"form-title\">Edit Product</h2>\n      <form\n        @submit.prevent=\"updateProduct\"\n        enctype=\"multipart/form-data\"\n        class=\"form-grid\"\n      >\n        <!-- Row 1: Name & Quantity -->\n        <div class=\"form-group\">\n          <label>Item Name</label>\n          <input v-model=\"form.name\" type=\"text\" placeholder=\"Item Name\" />\n        </div>\n        <div class=\"form-group\">\n          <label>Quantity</label>\n          <input\n            v-model.number=\"form.quantity\"\n            type=\"number\"\n            min=\"0\"\n            placeholder=\"Quantity\"\n          />\n        </div>\n\n        <!-- Row 2: Original Price & Discount Price -->\n        <div class=\"form-group\">\n          <label>Original Price</label>\n          <input\n            v-model.number=\"form.originalPrice\"\n            type=\"number\"\n            placeholder=\"Original Price\"\n          />\n        </div>\n        <div class=\"form-group\">\n          <label>Discount Price</label>\n          <input\n            v-model.number=\"form.discountPrice\"\n            type=\"number\"\n            placeholder=\"Discount Price\"\n          />\n        </div>\n        <div class=\"form-group\">\n          <label>Cost Price</label>\n          <input\n            v-model.number=\"form.costPrice\"\n            type=\"number\"\n            placeholder=\"Cost Price\"\n          />\n        </div>\n\n        <!-- Row 3: Description (Full Width) -->\n        <div class=\"form-group full-width\">\n          <label>Description (4-20 chars)</label>\n          <textarea\n            v-model=\"form.description\"\n            placeholder=\"Description (4-20 chars)\"\n          ></textarea>\n        </div>\n\n        <!-- Row 4: Shape Selection -->\n        <div class=\"form-group full-width\">\n          <label>3D Shape</label>\n          <select v-model=\"form.shape\">\n            <option value=\"box\">Box (Carton)</option>\n            <option value=\"pillow\">Pillow (Packet/Chips)</option>\n            <option value=\"cylinder\">Cylinder (Bottle/Can)</option>\n          </select>\n        </div>\n\n        <!-- Row 5: File Upload -->\n        <div class=\"form-group full-width\">\n          <label>Product Image</label>\n          <input\n            id=\"image\"\n            type=\"file\"\n            @change=\"handleFileUpload\"\n            accept=\"image/*\"\n          />\n        </div>\n\n        <!-- New Row: 3D Model Upload -->\n        <div class=\"form-group full-width\">\n          <label>3D Model (.glb, .gltf) - Optional</label>\n          <input\n            id=\"model3D\"\n            type=\"file\"\n            @change=\"handleModelUpload\"\n            accept=\".glb,.gltf\"\n          />\n        </div>\n\n        <!-- Current Image Preview -->\n        <div v-if=\"form.image && !imageFile\" class=\"image-preview-container\">\n          <img\n            :src=\"getImageUrl(form.image)\"\n            alt=\"Current Product\"\n            class=\"image-preview\"\n          />\n        </div>\n\n        <!-- New Image Preview -->\n        <div v-if=\"newImagePreview\" class=\"image-preview-container\">\n          <img :src=\"newImagePreview\" alt=\"New Preview\" class=\"image-preview\" />\n        </div>\n\n        <!-- Row 5: Submit Button (Full Width) -->\n        <div class=\"form-group full-width button-group\">\n          <button type=\"submit\" :disabled=\"loading\" class=\"btn-submit\">\n            {{ loading ? \"Updating...\" : \"Update Product\" }}\n          </button>\n        </div>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from \"@/utils/axios\";\n\nexport default {\n  name: \"ProductEdit\",\n  props: {\n    productId: {\n      type: String,\n      required: true,\n    },\n  },\n  data() {\n    return {\n      form: {\n        name: \"\",\n        description: \"\",\n        originalPrice: null,\n        discountPrice: null,\n        costPrice: null,\n        quantity: null,\n        image: \"\",\n        model3D: \"\",\n        shape: \"box\",\n      },\n      imageFile: null,\n      model3DFile: null,\n      newImagePreview: null,\n      loading: false,\n    };\n  },\n  async mounted() {\n    await this.fetchProduct();\n  },\n  methods: {\n    getImageUrl(path) {\n      return path.startsWith(\"/\") ? path : path;\n    },\n    async fetchProduct() {\n      try {\n        const res = await axios.get(\n          `/api/products/getproduct/${this.productId}`\n        );\n        if (res.data.success) {\n          const product = res.data.product;\n          this.form = {\n            name: product.name,\n            description: product.description,\n            originalPrice: product.originalPrice,\n            discountPrice: product.discountPrice,\n            costPrice: product.costPrice,\n            quantity: product.quantity,\n            image: product.image || \"\",\n            model3D: product.model3D || \"\",\n            shape: product.shape || \"box\",\n          };\n        }\n      } catch (err) {\n        console.error(\n          \"Error fetching product:\",\n          err.response?.data || err.message\n        );\n      }\n    },\n    handleFileUpload(e) {\n      this.imageFile = e.target.files[0];\n      if (this.imageFile) {\n        const reader = new FileReader();\n        reader.onload = (event) => {\n          this.newImagePreview = event.target.result;\n        };\n        reader.readAsDataURL(this.imageFile);\n      }\n    },\n    handleModelUpload(e) {\n      this.model3DFile = e.target.files[0];\n    },\n    async updateProduct() {\n      this.loading = true;\n      try {\n        const formData = new FormData();\n\n        Object.keys(this.form).forEach((key) => {\n          if (this.form[key] !== null && this.form[key] !== \"\") {\n            if (key !== \"image\" && key !== \"model3D\") {\n              formData.append(key, this.form[key]);\n            }\n          }\n        });\n\n        if (this.imageFile) {\n          formData.append(\"image\", this.imageFile);\n        }\n\n        if (this.model3DFile) {\n          formData.append(\"model3D\", this.model3DFile);\n        }\n\n        const res = await axios.put(\n          `/api/products/updateproduct/${this.productId}`,\n          formData,\n          { headers: { \"Content-Type\": \"multipart/form-data\" } }\n        );\n\n        if (res.data.success) {\n          this.$emit(\"updated\");\n        }\n      } catch (err) {\n        console.error(err.response?.data || err.message);\n      } finally {\n        this.loading = false;\n      }\n    },\n  },\n};\n</script>\n\n<style scoped>\n.form-wrapper {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 80vh;\n}\n\n.form-card {\n  background: #fff;\n  padding: 20px;\n  width: 100%;\n  border-radius: 12px;\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n}\n\n.form-title {\n  text-align: center;\n  margin-bottom: 16px;\n  font-size: 18px;\n  font-weight: 600;\n  color: #1e293b;\n}\n\n.form-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n}\n\n.form-group {\n  display: flex;\n  flex-direction: column;\n}\n\n.form-group.full-width {\n  grid-column: 1 / -1;\n}\n\n.form-group label {\n  font-size: 12px;\n  font-weight: 500;\n  color: #475569;\n  margin-bottom: 4px;\n}\n\n.form-group input,\n.form-group textarea,\n.form-group select {\n  padding: 8px 10px;\n  border: 1px solid #cbd5e1;\n  border-radius: 6px;\n  font-size: 13px;\n  font-family: inherit;\n  transition: border-color 0.2s;\n}\n\n.form-group input:focus,\n.form-group textarea:focus,\n.form-group select:focus {\n  outline: none;\n  border-color: #2563eb;\n  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);\n}\n\n.form-group textarea {\n  resize: none;\n  height: 70px;\n  min-height: 70px;\n}\n\n.btn-submit {\n  background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);\n  color: white;\n  font-weight: 600;\n  border: none;\n  cursor: pointer;\n  padding: 10px 16px;\n  border-radius: 6px;\n  transition: all 0.3s ease;\n  width: 100%;\n}\n\n.btn-submit:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);\n}\n\n.btn-submit:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.image-preview-container {\n  grid-column: 1 / -1;\n  display: flex;\n  justify-content: center;\n  padding: 8px 0;\n}\n\n.image-preview {\n  max-width: 120px;\n  max-height: 120px;\n  border-radius: 8px;\n  border: 2px solid #e2e8f0;\n  object-fit: contain;\n}\n\n.button-group {\n  margin-top: 8px;\n}\n</style>\n"],"mappings":";;AAqHA,OAAOA,KAAI,MAAO,eAAe;AAEjC,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,KAAK,EAAE;IACLC,SAAS,EAAE;MACTC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJP,IAAI,EAAE,EAAE;QACRQ,WAAW,EAAE,EAAE;QACfC,aAAa,EAAE,IAAI;QACnBC,aAAa,EAAE,IAAI;QACnBC,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,IAAI;QACdC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE,EAAE;QACXC,KAAK,EAAE;MACT,CAAC;MACDC,SAAS,EAAE,IAAI;MACfC,WAAW,EAAE,IAAI;MACjBC,eAAe,EAAE,IAAI;MACrBC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAM,IAAI,CAACC,YAAY,CAAC,CAAC;EAC3B,CAAC;EACDC,OAAO,EAAE;IACPC,WAAWA,CAACC,IAAI,EAAE;MAChB,OAAOA,IAAI,CAACC,UAAU,CAAC,GAAG,IAAID,IAAG,GAAIA,IAAI;IAC3C,CAAC;IACD,MAAMH,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMK,GAAE,GAAI,MAAM3B,KAAK,CAAC4B,GAAG,CACzB,4BAA4B,IAAI,CAACzB,SAAS,EAC5C,CAAC;QACD,IAAIwB,GAAG,CAACpB,IAAI,CAACsB,OAAO,EAAE;UACpB,MAAMC,OAAM,GAAIH,GAAG,CAACpB,IAAI,CAACuB,OAAO;UAChC,IAAI,CAACtB,IAAG,GAAI;YACVP,IAAI,EAAE6B,OAAO,CAAC7B,IAAI;YAClBQ,WAAW,EAAEqB,OAAO,CAACrB,WAAW;YAChCC,aAAa,EAAEoB,OAAO,CAACpB,aAAa;YACpCC,aAAa,EAAEmB,OAAO,CAACnB,aAAa;YACpCC,SAAS,EAAEkB,OAAO,CAAClB,SAAS;YAC5BC,QAAQ,EAAEiB,OAAO,CAACjB,QAAQ;YAC1BC,KAAK,EAAEgB,OAAO,CAAChB,KAAI,IAAK,EAAE;YAC1BC,OAAO,EAAEe,OAAO,CAACf,OAAM,IAAK,EAAE;YAC9BC,KAAK,EAAEc,OAAO,CAACd,KAAI,IAAK;UAC1B,CAAC;QACH;MACF,EAAE,OAAOe,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CACX,yBAAyB,EACzBF,GAAG,CAACG,QAAQ,EAAE3B,IAAG,IAAKwB,GAAG,CAACI,OAC5B,CAAC;MACH;IACF,CAAC;IACDC,gBAAgBA,CAACC,CAAC,EAAE;MACl