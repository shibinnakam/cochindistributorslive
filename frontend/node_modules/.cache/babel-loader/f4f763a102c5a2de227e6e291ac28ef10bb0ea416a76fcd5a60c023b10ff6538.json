{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"ContactPage\",\n  data() {\n    return {\n      form: {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      }\n    };\n  },\n  methods: {\n    submitForm() {\n      alert(\"Message sent successfully! We will get back to you soon.\");\n      this.form = {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      };\n    }\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver(entries => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, {\n          threshold: 0.1\n        });\n        observer.observe(el);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","form","firstName","lastName","email","phone","message","methods","submitForm","alert","directives","animateOnScroll","mounted","el","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","classList","add","unobserve","threshold","observe"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\Contact.vue"],"sourcesContent":["<template>\n  <div class=\"contact-page\">\n    <!-- Header Section -->\n    <section class=\"contact-header\">\n      <div class=\"header-overlay\"></div>\n      <h1 class=\"page-title\">Contact Us</h1>\n    </section>\n\n    <!-- Contact Section -->\n    <section class=\"contact-section container\">\n      <div class=\"contact-grid\">\n        <!-- Info Column -->\n        <div class=\"contact-info\" v-animate-on-scroll>\n          <h2 class=\"section-title\">Get In Touch</h2>\n          <p class=\"info-intro\">We'd love to hear from you. Whether you have a question about our products, pricing, or anything else, our team is ready to answer all your questions.</p>\n          \n          <div class=\"info-items\">\n            <div class=\"info-item\">\n              <div class=\"icon-box\"><i class=\"fas fa-map-marker-alt\"></i></div>\n              <div class=\"item-text\">\n                <h3>Our Location</h3>\n                <p>123 Bakery Street, Cochin, Kerala, India</p>\n              </div>\n            </div>\n            <div class=\"info-item\">\n              <div class=\"icon-box\"><i class=\"fas fa-phone-alt\"></i></div>\n              <div class=\"item-text\">\n                <h3>Phone Number</h3>\n                <p>+91 98765 43210</p>\n              </div>\n            </div>\n            <div class=\"info-item\">\n              <div class=\"icon-box\"><i class=\"fas fa-envelope\"></i></div>\n              <div class=\"item-text\">\n                <h3>Email Address</h3>\n                <p>hello@cochindistributors.com</p>\n              </div>\n            </div>\n            <div class=\"info-item\">\n              <div class=\"icon-box\"><i class=\"fas fa-clock\"></i></div>\n              <div class=\"item-text\">\n                <h3>Working Hours</h3>\n                <p>Mon - Sat: 9:00 AM - 8:00 PM</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"social-links\">\n            <a href=\"#\" class=\"social-link\"><i class=\"fab fa-facebook-f\"></i></a>\n            <a href=\"#\" class=\"social-link\"><i class=\"fab fa-instagram\"></i></a>\n            <a href=\"#\" class=\"social-link\"><i class=\"fab fa-twitter\"></i></a>\n          </div>\n        </div>\n\n        <!-- Form Column -->\n        <div class=\"contact-form-wrapper\" v-animate-on-scroll>\n          <div class=\"form-card\">\n            <form @submit.prevent=\"submitForm\">\n              <div class=\"form-row\">\n                <div class=\"form-group\">\n                  <label>First Name</label>\n                  <input type=\"text\" v-model=\"form.firstName\" placeholder=\"John\" required />\n                </div>\n                <div class=\"form-group\">\n                  <label>Last Name</label>\n                  <input type=\"text\" v-model=\"form.lastName\" placeholder=\"Doe\" required />\n                </div>\n              </div>\n              <div class=\"form-group\">\n                <label>Email Address</label>\n                <input type=\"email\" v-model=\"form.email\" placeholder=\"john@example.com\" required />\n              </div>\n              <div class=\"form-group\">\n                <label>Phone Number</label>\n                <input type=\"tel\" v-model=\"form.phone\" placeholder=\"+91 ...\" />\n              </div>\n              <div class=\"form-group\">\n                <label>Your Message</label>\n                <textarea v-model=\"form.message\" rows=\"5\" placeholder=\"How can we help you?\" required></textarea>\n              </div>\n              <button type=\"submit\" class=\"btn-submit\">Send Message</button>\n            </form>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Map Placeholder/Integration Section -->\n    <section class=\"map-section\">\n      <div class=\"map-placeholder\">\n        <div class=\"map-overlay\">\n          <p><i class=\"fas fa-map-marked-alt\"></i></p>\n          <span>Find us on Google Maps</span>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"ContactPage\",\n  data() {\n    return {\n      form: {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\",\n      },\n    };\n  },\n  methods: {\n    submitForm() {\n      alert(\"Message sent successfully! We will get back to you soon.\");\n      this.form = {\n        firstName: \"\",\n        lastName: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\",\n      };\n    },\n  },\n  directives: {\n    animateOnScroll: {\n      mounted(el) {\n        const observer = new IntersectionObserver((entries) => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting) {\n              el.classList.add('is-visible');\n              observer.unobserve(el);\n            }\n          });\n        }, { threshold: 0.1 });\n        observer.observe(el);\n      }\n    }\n  }\n};\n</script>\n\n<style scoped>\n.contact-page {\n  font-family: 'Plus Jakarta Sans', sans-serif;\n  color: #5d4037;\n  background-color: #fffdfa;\n  padding-top: 80px;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 2rem;\n}\n\n/* --- Header --- */\n.contact-header {\n  height: 250px;\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: url('https://images.unsplash.com/photo-1555507036-ab1f4038808a?auto=format&fit=crop&q=80&w=1200') center/cover no-repeat;\n}\n\n.header-overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(255, 255, 255, 0.45);\n}\n\n.page-title {\n  position: relative;\n  z-index: 1;\n  font-family: 'Dancing Script', cursive;\n  font-size: 4rem;\n  color: #3e2723;\n  font-weight: 700;\n}\n\n/* --- Contact Section --- */\n.contact-section {\n  padding: 8rem 0;\n}\n\n.contact-grid {\n  display: grid;\n  grid-template-columns: 1fr 1.2fr;\n  gap: 6rem;\n  align-items: start;\n}\n\n.contact-info {\n  opacity: 0;\n  transform: translateX(-30px);\n  transition: all 0.8s ease;\n}\n\n.contact-info.is-visible {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n.section-title {\n  font-family: 'Dancing Script', cursive;\n  font-size: 3.2rem;\n  margin-bottom: 1.5rem;\n  color: #3e2723;\n}\n\n.info-intro {\n  font-size: 1.1rem;\n  line-height: 1.8;\n  color: #8d6e63;\n  margin-bottom: 3.5rem;\n}\n\n.info-items {\n  display: flex;\n  flex-direction: column;\n  gap: 2.5rem;\n}\n\n.info-item {\n  display: flex;\n  gap: 1.5rem;\n  align-items: flex-start;\n}\n\n.icon-box {\n  width: 55px;\n  height: 55px;\n  background: white;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1.4rem;\n  color: #efa962;\n  box-shadow: 0 10px 25px rgba(0,0,0,0.05);\n  flex-shrink: 0;\n}\n\n.item-text h3 {\n  font-size: 1.25rem;\n  font-weight: 700;\n  margin-bottom: 0.4rem;\n  color: #3e2723;\n}\n\n.item-text p {\n  font-size: 1rem;\n  color: #8d6e63;\n}\n\n.social-links {\n  display: flex;\n  gap: 1rem;\n  margin-top: 4rem;\n}\n\n.social-link {\n  width: 45px;\n  height: 45px;\n  border-radius: 50%;\n  border: 1px solid #e0d5d0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #5d4037;\n  transition: all 0.3s ease;\n  text-decoration: none;\n}\n\n.social-link:hover {\n  background-color: #efa962;\n  color: white;\n  border-color: #efa962;\n  transform: translateY(-3px);\n}\n\n/* --- Form Card --- */\n.contact-form-wrapper {\n  opacity: 0;\n  transform: translateX(30px);\n  transition: all 0.8s ease 0.2s;\n}\n\n.contact-form-wrapper.is-visible {\n  opacity: 1;\n  transform: translateX(0);\n}\n\n.form-card {\n  background: white;\n  padding: 3.5rem;\n  border-radius: 12px;\n  box-shadow: 0 30px 60px rgba(0,0,0,0.06);\n}\n\n.form-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 1.5rem;\n}\n\n.form-group {\n  margin-bottom: 1.5rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.form-group label {\n  font-size: 0.9rem;\n  font-weight: 700;\n  color: #3e2723;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.form-group input,\n.form-group textarea {\n  padding: 1rem 1.25rem;\n  border-radius: 6px;\n  border: 1px solid #e2e8f0;\n  background-color: #f8fafc;\n  font-family: inherit;\n  font-size: 1rem;\n  transition: all 0.3s ease;\n}\n\n.form-group input:focus,\n.form-group textarea:focus {\n  outline: none;\n  border-color: #efa962;\n  background-color: white;\n  box-shadow: 0 0 0 4px rgba(239, 169, 98, 0.1);\n}\n\n.btn-submit {\n  width: 100%;\n  background-color: #3e2723;\n  color: white;\n  border: none;\n  padding: 1.25rem;\n  border-radius: 6px;\n  font-weight: 700;\n  font-size: 1rem;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin-top: 1rem;\n}\n\n.btn-submit:hover {\n  background-color: #efa962;\n  transform: translateY(-2px);\n  box-shadow: 0 10px 20px rgba(239, 169, 98, 0.2);\n}\n\n/* --- Map Section --- */\n.map-section {\n  height: 450px;\n  background-color: #f1f5f9;\n}\n\n.map-placeholder {\n  height: 100%;\n  width: 100%;\n  background: url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&q=80&w=1200') center/cover no-repeat;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.map-overlay {\n  background: white;\n  padding: 2.5rem 4rem;\n  border-radius: 10px;\n  text-align: center;\n  box-shadow: 0 20px 50px rgba(0,0,0,0.1);\n}\n\n.map-overlay i {\n  font-size: 2.5rem;\n  color: #efa962;\n  margin-bottom: 1rem;\n}\n\n.map-overlay span {\n  display: block;\n  font-weight: 700;\n  color: #3e2723;\n}\n\n@media (max-width: 1024px) {\n  .contact-grid {\n    grid-template-columns: 1fr;\n    gap: 4rem;\n  }\n}\n\n@media (max-width: 768px) {\n  .form-row {\n    grid-template-columns: 1fr;\n  }\n  .page-title { font-size: 3rem; }\n  .section-title { font-size: 2.8rem; }\n  .form-card { padding: 2rem; }\n}\n</style>\n"],"mappings":";;AAoGA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,SAAS,EAAE,EAAE;QACbC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE;MACX;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAAA,EAAG;MACXC,KAAK,CAAC,0DAA0D,CAAC;MACjE,IAAI,CAACR,IAAG,GAAI;QACVC,SAAS,EAAE,EAAE;QACbC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE;MACX,CAAC;IACH;EACF,CAAC;EACD