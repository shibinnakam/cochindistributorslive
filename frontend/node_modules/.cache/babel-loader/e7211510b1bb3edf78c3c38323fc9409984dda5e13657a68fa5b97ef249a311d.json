{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport \"@/assets/styles/AdminPage.css\";\nimport axios from \"axios\";\nimport socket from \"@/socket\";\nimport AddProduct from \"@/views/AddProduct.vue\";\nimport ProductList from \"@/views/ProductList.vue\";\nimport ProductEdit from \"@/views/ProductEdit.vue\";\nimport ProductCategory from \"@/views/AddCategory.vue\";\nimport StaffManagement from \"@/views/StaffManagement.vue\";\n// eslint-disable-next-line no-unused-vars\nimport AdminOrders from \"@/views/AdminOrders.vue\";\nimport AdminLeaves from \"@/views/AdminLeaves.vue\";\nimport ChatWindow from \"@/views/ChatWindow.vue\";\nconst API_BASE_URL = \"http://localhost:5000/api\";\nexport default {\n  name: \"AdminPage\",\n  components: {\n    AddProduct,\n    ProductList,\n    ProductEdit,\n    ProductCategory,\n    StaffManagement,\n    AdminOrders,\n    AdminLeaves,\n    ChatWindow\n  },\n  data() {\n    return {\n      selectedMenu: \"dashboard\",\n      showAddProductModal: false,\n      showListProductsModal: false,\n      showEditProductModal: false,\n      editProductId: null,\n      dashboardLoading: false,\n      // Stats\n      totalProducts: 0,\n      totalCategories: 0,\n      totalStaff: 0,\n      activeStaff: 0,\n      pendingLeaves: 0,\n      approvedLeaves: 0,\n      totalInventory: 0,\n      unreadMessageCount: 0,\n      totalEnquiries: 0,\n      pendingReviews: 0,\n      totalPurchases: 0,\n      totalProfit: 0,\n      salesTimeframe: \"all\",\n      analyticsData: null,\n      displayedPurchases: 0,\n      displayedProfit: 0,\n      reviewTab: \"pending\",\n      reviewsLoading: false,\n      currentReviews: [],\n      actionLoading: false,\n      messageInterval: null,\n      // Password Change\n      passwordForm: {\n        currentPassword: \"\",\n        newPassword: \"\",\n        confirmPassword: \"\"\n      },\n      passwordError: \"\",\n      passwordSuccess: \"\",\n      passwordLoading: false\n    };\n  },\n  mounted() {\n    this.fetchDashboardStats();\n    this.fetchUnreadMessages();\n    this.messageInterval = setInterval(() => {\n      this.fetchUnreadMessages();\n    }, 5000); // Reduced frequency\n  },\n  beforeUnmount() {\n    if (this.messageInterval) clearInterval(this.messageInterval);\n  },\n  methods: {\n    getPageTitle(menu) {\n      const titles = {\n        dashboard: \"Dashboard Overview\",\n        addProduct: \"Add New Product\",\n        listProducts: \"Product Catalog\",\n        addCategory: \"Category Management\",\n        staffManagement: \"Staff Management\",\n        orders: \"Order Management\",\n        \"approve-leaves\": \"Leave Requests\",\n        chat: \"Messages & Communications\",\n        changePassword: \"Change Password\"\n      };\n      return titles[menu] || \"Dashboard\";\n    },\n    async handleChangePassword() {\n      this.passwordError = \"\";\n      this.passwordSuccess = \"\";\n      if (this.passwordForm.newPassword !== this.passwordForm.confirmPassword) {\n        this.passwordError = \"New passwords do not match.\";\n        return;\n      }\n      this.passwordLoading = true;\n      try {\n        const token = localStorage.getItem(\"token\");\n        const res = await axios.post(`${API_BASE_URL}/auth/change-password`, {\n          currentPassword: this.passwordForm.currentPassword,\n          newPassword: this.passwordForm.newPassword\n        }, {\n          headers: {\n            Authorization: `Bearer ${token}`\n          }\n        });\n        this.passwordSuccess = res.data.msg || \"Password changed successfully.\";\n        this.passwordForm = {\n          currentPassword: \"\",\n          newPassword: \"\",\n          confirmPassword: \"\"\n        };\n      } catch (err) {\n        this.passwordError = err.response?.data?.msg || \"Failed to change password.\";\n      } finally {\n        this.passwordLoading = false;\n      }\n    },\n    async fetchDashboardStats() {\n      this.dashboardLoading = true;\n      try {\n        const [productsRes, categoriesRes, staffRes, leavesRes, reviewsRes, salesRes] = await Promise.all([axios.get(`${API_BASE_URL}/products/getproduct`), axios.get(`${API_BASE_URL}/categories`), axios.get(`${API_BASE_URL}/staff`), axios.get(`${API_BASE_URL}/leaves/all`), axios.get(`${API_BASE_URL}/reviews/admin/pending`, {\n          headers: {\n            Authorization: `Bearer ${localStorage.getItem(\"token\")}`\n          }\n        }), axios.get(`${API_BASE_URL}/orders/admin/sales-analytics`, {\n          headers: {\n            Authorization: `Bearer ${localStorage.getItem(\"token\")}`\n          }\n        })]);\n        if (productsRes.data.success && productsRes.data.products) {\n          this.totalProducts = productsRes.data.products.length;\n          this.totalInventory = productsRes.data.products.reduce((sum, p) => sum + (p.quantity || 0), 0);\n        }\n        if (Array.isArray(categoriesRes.data)) {\n          this.totalCategories = categoriesRes.data.length;\n        }\n        if (staffRes.data.success && Array.isArray(staffRes.data.staff)) {\n          this.totalStaff = staffRes.data.staff.length;\n          this.activeStaff = staffRes.data.staff.filter(s => s.status === \"active\").length;\n        }\n        if (Array.isArray(leavesRes.data)) {\n          this.pendingLeaves = leavesRes.data.filter(l => l.status === \"Pending\").length;\n          this.approvedLeaves = leavesRes.data.filter(l => l.status === \"Approved\").length;\n        }\n        if (Array.isArray(reviewsRes.data)) {\n          this.pendingReviews = reviewsRes.data.length;\n        }\n        if (salesRes.data) {\n          this.analyticsData = salesRes.data;\n          this.totalPurchases = salesRes.data.totalPurchases;\n          this.totalProfit = salesRes.data.totalProfit;\n          this.updateDisplayedStats();\n        }\n      } catch (error) {\n        console.error(\"Error loading stats:\", error);\n      } finally {\n        this.dashboardLoading = false;\n      }\n    },\n    updateDisplayedStats() {\n      if (!this.analyticsData) return;\n      if (this.salesTimeframe === \"all\") {\n        this.displayedPurchases = this.totalPurchases;\n        this.displayedProfit = this.totalProfit;\n      } else {\n        const now = new Date();\n        let key = \"\";\n        let dataSet = null;\n        if (this.salesTimeframe === \"today\") {\n          key = now.toISOString().split(\"T\")[0];\n          dataSet = this.analyticsData.daily;\n        } else if (this.salesTimeframe === \"month\") {\n          key = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, \"0\")}`;\n          dataSet = this.analyticsData.monthly;\n        } else if (this.salesTimeframe === \"year\") {\n          key = now.getFullYear().toString();\n          dataSet = this.analyticsData.yearly;\n        }\n        if (dataSet) {\n          this.displayedPurchases = dataSet.purchases[key] || 0;\n          this.displayedProfit = dataSet.profit[key] || 0;\n        }\n      }\n    },\n    async fetchUnreadMessages() {\n      try {\n        const token = localStorage.getItem(\"token\");\n        if (!token) return;\n        const res = await axios.get(\"http://localhost:5000/api/messages/unread-count\", {\n          headers: {\n            Authorization: `Bearer ${token}`\n          }\n        });\n        if (res.data.success) this.unreadMessageCount = res.data.unreadCount;\n      } catch (e) {\n        console.error(\"Msg Error\", e);\n      }\n    },\n    logout() {\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"user\");\n      this.$router.push(\"/\");\n    },\n    closeAddProductModal() {\n      this.showAddProductModal = false;\n      this.fetchDashboardStats();\n    },\n    closeListProductsModal() {\n      this.showListProductsModal = false;\n      this.fetchDashboardStats();\n    },\n    openEditProductModal(id) {\n      this.editProductId = id;\n      this.showEditProductModal = true;\n    },\n    handleProductUpdated() {\n      this.showEditProductModal = false;\n      this.showListProductsModal = false;\n      this.fetchDashboardStats();\n    }\n  }\n};","map":{"version":3,"names":["axios","socket","AddProduct","ProductList","ProductEdit","ProductCategory","StaffManagement","AdminOrders","AdminLeaves","ChatWindow","API_BASE_URL","name","components","data","selectedMenu","showAddProductModal","showListProductsModal","showEditProductModal","editProductId","dashboardLoading","totalProducts","totalCategories","totalStaff","activeStaff","pendingLeaves","approvedLeaves","totalInventory","unreadMessageCount","totalEnquiries","pendingReviews","totalPurchases","totalProfit","salesTimeframe","analyticsData","displayedPurchases","displayedProfit","reviewTab","reviewsLoading","currentReviews","actionLoading","messageInterval","passwordForm","currentPassword","newPassword","confirmPassword","passwordError","passwordSuccess","passwordLoading","mounted","fetchDashboardStats","fetchUnreadMessages","setInterval","beforeUnmount","clearInterval","methods","getPageTitle","menu","titles","dashboard","addProduct","listProducts","addCategory","staffManagement","orders","chat","changePassword","handleChangePassword","token","localStorage","getItem","res","post","headers","Authorization","msg","err","response","productsRes","categoriesRes","staffRes","leavesRes","reviewsRes","salesRes","Promise","all","get","success","products","length","reduce","sum","p","quantity","Array","isArray","staff","filter","s","status","l","updateDisplayedStats","error","console","now","Date","key","dataSet","toISOString","split","daily","getFullYear","String","getMonth","padStart","monthly","toString","yearly","purchases","profit","unreadCount","e","logout","removeItem","$router","push","closeAddProductModal","closeListProductsModal","openEditProductModal","id","handleProductUpdated"],"sources":["C:\\Users\\LENOVO\\Music\\OneDrive\\Pictures\\distribution-agency-project\\frontend\\src\\views\\AdminPage.vue"],"sourcesContent":["<template>\n  <div class=\"admin-container\">\n    <!-- Sidebar Navigation -->\n    <aside class=\"sidebar\">\n      <div class=\"brand\">\n        <div class=\"brand-logo\">🛍️</div>\n        <div class=\"brand-text\">ShopAdmin</div>\n      </div>\n\n      <nav class=\"nav-menu\">\n        <div class=\"nav-section\">\n          <span class=\"nav-section-title\">Main</span>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'dashboard' }\"\n            @click.prevent=\"selectedMenu = 'dashboard'\"\n          >\n            <span class=\"icon\">📊</span>\n            Dashboard\n          </a>\n        </div>\n\n        <div class=\"nav-section\">\n          <span class=\"nav-section-title\">Catalog</span>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'addProduct' }\"\n            @click.prevent=\"showAddProductModal = true\"\n          >\n            <span class=\"icon\">➕</span>\n            Add Product\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'listProducts' }\"\n            @click.prevent=\"showListProductsModal = true\"\n          >\n            <span class=\"icon\">📦</span>\n            Product List\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'addCategory' }\"\n            @click.prevent=\"selectedMenu = 'addCategory'\"\n          >\n            <span class=\"icon\">🏷️</span>\n            Categories\n          </a>\n        </div>\n\n        <div class=\"nav-section\">\n          <span class=\"nav-section-title\">People & Operations</span>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'staffManagement' }\"\n            @click.prevent=\"selectedMenu = 'staffManagement'\"\n          >\n            <span class=\"icon\">👥</span>\n            Staff\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'orders' }\"\n            @click.prevent=\"selectedMenu = 'orders'\"\n          >\n            <span class=\"icon\">📦</span>\n            Orders\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'approve-leaves' }\"\n            @click.prevent=\"selectedMenu = 'approve-leaves'\"\n          >\n            <span class=\"icon\">📅</span>\n            Leaves\n            <span v-if=\"pendingLeaves > 0\" class=\"badge-pill\">{{\n              pendingLeaves\n            }}</span>\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'chat' }\"\n            @click.prevent=\"selectedMenu = 'chat'\"\n          >\n            <span class=\"icon\">💬</span>\n            Messages\n            <span v-if=\"unreadMessageCount > 0\" class=\"badge-pill\">{{\n              unreadMessageCount\n            }}</span>\n          </a>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'reviews' }\"\n            @click.prevent=\"selectedMenu = 'reviews'\"\n          >\n            <span class=\"icon\">⭐</span>\n            Reviews\n            <span v-if=\"pendingReviews > 0\" class=\"badge-pill\">{{\n              pendingReviews\n            }}</span>\n          </a>\n        </div>\n\n        <div class=\"nav-section\">\n          <span class=\"nav-section-title\">Account</span>\n          <a\n            href=\"#\"\n            class=\"nav-item\"\n            :class=\"{ active: selectedMenu === 'changePassword' }\"\n            @click.prevent=\"selectedMenu = 'changePassword'\"\n          >\n            <span class=\"icon\">🔑</span>\n            Change Password\n          </a>\n          <a href=\"#\" class=\"nav-item logout\" @click.prevent=\"logout\">\n            <span class=\"icon\">🚪</span>\n            Logout\n          </a>\n        </div>\n      </nav>\n    </aside>\n\n    <!-- Main Content Area -->\n    <main class=\"main-content\">\n      <!-- Top Header -->\n      <header class=\"top-header\">\n        <div class=\"header-left\">\n          <h1 class=\"page-title\">\n            {{ getPageTitle(selectedMenu) }}\n          </h1>\n        </div>\n        <div class=\"header-right\">\n          <div class=\"search-bar\">\n            <span class=\"search-icon\">🔍</span>\n            <input type=\"text\" placeholder=\"Search...\" />\n          </div>\n          <div class=\"user-profile\">\n            <div class=\"avatar\">A</div>\n            <div class=\"user-info\">\n              <span class=\"name\">Administrator</span>\n              <span class=\"role\">Super Admin</span>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      <!-- Content Views -->\n      <div class=\"content-wrapper\">\n        <!-- Dashboard View -->\n        <div v-if=\"selectedMenu === 'dashboard'\" class=\"dashboard-view\">\n          <!-- Stats Cards -->\n          <div class=\"stats-grid\">\n            <div class=\"stat-card\">\n              <div class=\"stat-icon blue-bg\">📦</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ totalProducts }}</span>\n                <span class=\"stat-label\">Total Products</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon orange-bg\">🏷️</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ totalCategories }}</span>\n                <span class=\"stat-label\">Categories</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon green-bg\">👥</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ totalStaff }}</span>\n                <span class=\"stat-label\">Total Staff</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon purple-bg\">⚡</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ activeStaff }}</span>\n                <span class=\"stat-label\">Active Staff</span>\n              </div>\n            </div>\n          </div>\n\n          <!-- Secondary Stats Row -->\n          <div class=\"stats-grid mt-4\">\n            <div class=\"stat-card\">\n              <div class=\"stat-icon red-bg\">⏳</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ pendingLeaves }}</span>\n                <span class=\"stat-label\">Pending Leaves</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon teal-bg\">✅</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ approvedLeaves }}</span>\n                <span class=\"stat-label\">Approved Leaves</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon pink-bg\">📊</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ totalInventory }}</span>\n                <span class=\"stat-label\">Total Inventory</span>\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon indigo-bg\">📧</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\">{{ totalEnquiries || 0 }}</span>\n                <span class=\"stat-label\">Enquiries</span>\n              </div>\n            </div>\n          </div>\n\n          <!-- Sales Timeframe Selector -->\n          <div class=\"timeframe-selector mt-4\">\n            <button\n              v-for=\"timeframe in ['all', 'today', 'month', 'year']\"\n              :key=\"timeframe\"\n              :class=\"{ active: salesTimeframe === timeframe }\"\n              @click=\"\n                salesTimeframe = timeframe;\n                updateDisplayedStats();\n              \"\n              class=\"timeframe-btn\"\n            >\n              {{ timeframe.charAt(0).toUpperCase() + timeframe.slice(1) }}\n            </button>\n          </div>\n\n          <!-- Sales Stats Row -->\n          <div class=\"stats-grid mt-2\">\n            <div class=\"stat-card\">\n              <div class=\"stat-icon green-bg\">💰</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\"\n                  >₹{{ displayedPurchases.toLocaleString() }}</span\n                >\n                <span class=\"stat-label\"\n                  >{{\n                    salesTimeframe === \"all\"\n                      ? \"Total\"\n                      : salesTimeframe.charAt(0).toUpperCase() +\n                        salesTimeframe.slice(1)\n                  }}\n                  Purchases</span\n                >\n              </div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon blue-bg\">📈</div>\n              <div class=\"stat-details\">\n                <span class=\"stat-value\"\n                  >₹{{ displayedProfit.toLocaleString() }}</span\n                >\n                <span class=\"stat-label\"\n                  >{{\n                    salesTimeframe === \"all\"\n                      ? \"Total\"\n                      : salesTimeframe.charAt(0).toUpperCase() +\n                        salesTimeframe.slice(1)\n                  }}\n                  Profit</span\n                >\n              </div>\n            </div>\n          </div>\n\n          <!-- Recent Activity Section (Mockup for professional look) -->\n          <div class=\"dashboard-sections\">\n            <div class=\"section-card recent-orders\">\n              <div class=\"section-header\">\n                <h3>Recent Activity</h3>\n                <button class=\"btn-link\">View All</button>\n              </div>\n              <table class=\"data-table\">\n                <thead>\n                  <tr>\n                    <th>ID</th>\n                    <th>Activity</th>\n                    <th>Status</th>\n                    <th>Date</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr>\n                    <td>#1024</td>\n                    <td>New Product Added</td>\n                    <td><span class=\"status-badge success\">Completed</span></td>\n                    <td>Just now</td>\n                  </tr>\n                  <tr>\n                    <td>#1023</td>\n                    <td>Staff Leave Request</td>\n                    <td><span class=\"status-badge warning\">Pending</span></td>\n                    <td>2 hours ago</td>\n                  </tr>\n                  <tr>\n                    <td>#1022</td>\n                    <td>Category Updated</td>\n                    <td><span class=\"status-badge info\">Updated</span></td>\n                    <td>Yesterday</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n        </div>\n\n        <!-- Other Views -->\n        <AddProduct v-if=\"selectedMenu === 'addProduct'\" />\n        <ProductCategory v-if=\"selectedMenu === 'addCategory'\" />\n        <ProductList v-if=\"selectedMenu === 'listProducts'\" />\n        <StaffManagement v-if=\"selectedMenu === 'staffManagement'\" />\n        <AdminOrders v-if=\"selectedMenu === 'orders'\" />\n        <AdminLeaves v-if=\"selectedMenu === 'approve-leaves'\" />\n        <ChatWindow v-if=\"selectedMenu === 'chat'\" />\n\n        <!-- Reviews View -->\n        <div v-if=\"selectedMenu === 'reviews'\" class=\"reviews-section\">\n          <div class=\"section-card\">\n            <div class=\"section-header\">\n              <h3>User Reviews Management</h3>\n              <div class=\"review-tabs\">\n                <button\n                  :class=\"{ active: reviewTab === 'pending' }\"\n                  @click=\"reviewTab = 'pending'\"\n                  class=\"tab-btn\"\n                >\n                  Pending Reviews\n                  <span v-if=\"pendingReviews > 0\" class=\"badge\">\n                    {{ pendingReviews }}\n                  </span>\n                </button>\n                <button\n                  :class=\"{ active: reviewTab === 'all' }\"\n                  @click=\"reviewTab = 'all'\"\n                  class=\"tab-btn\"\n                >\n                  All Reviews\n                </button>\n              </div>\n            </div>\n\n            <div class=\"reviews-list\">\n              <div v-if=\"reviewsLoading\" class=\"loading\">\n                Loading reviews...\n              </div>\n              <div v-else-if=\"currentReviews.length === 0\" class=\"no-reviews\">\n                No {{ reviewTab === \"pending\" ? \"pending\" : \"\" }} reviews found.\n              </div>\n              <div v-else class=\"reviews-grid\">\n                <div\n                  v-for=\"review in currentReviews\"\n                  :key=\"review._id\"\n                  class=\"review-card\"\n                >\n                  <div class=\"review-header\">\n                    <div class=\"user-info\">\n                      <div class=\"avatar\">\n                        {{ review.user.name.charAt(0).toUpperCase() }}\n                      </div>\n                      <div class=\"user-details\">\n                        <span class=\"user-name\">{{ review.user.name }}</span>\n                        <span class=\"user-email\">{{ review.user.email }}</span>\n                      </div>\n                    </div>\n                    <div class=\"review-rating\">\n                      <div class=\"stars\">\n                        <span\n                          v-for=\"star in 5\"\n                          :key=\"star\"\n                          :class=\"{ filled: star <= review.rating }\"\n                          class=\"star\"\n                        >\n                          ★\n                        </span>\n                      </div>\n                      <span class=\"rating-text\">{{ review.rating }}/5</span>\n                    </div>\n                  </div>\n\n                  <div class=\"review-product\">\n                    <div class=\"product-info\">\n                      <img\n                        v-if=\"review.product.imageFront\"\n                        :src=\"`http://localhost:5000/${review.product.imageFront}`\"\n                        alt=\"Product Image\"\n                        class=\"product-image\"\n                      />\n                      <div class=\"product-details\">\n                        <span class=\"product-label\">Product:</span>\n                        <span class=\"product-name\">{{\n                          review.product.name\n                        }}</span>\n                        <span class=\"product-id\"\n                          >ID: {{ review.product._id }}</span\n                        >\n                      </div>\n                    </div>\n                  </div>\n\n                  <div class=\"review-comment\">\n                    <p>{{ review.comment }}</p>\n                  </div>\n\n                  <div class=\"review-footer\">\n                    <span class=\"review-date\">\n                      {{ formatDate(review.createdAt) }}\n                    </span>\n                    <div class=\"review-actions\" v-if=\"reviewTab === 'pending'\">\n                      <button\n                        @click=\"approveReview(review._id)\"\n                        class=\"btn-approve\"\n                        :disabled=\"actionLoading\"\n                      >\n                        Approve\n                      </button>\n                      <button\n                        @click=\"deleteReview(review._id)\"\n                        class=\"btn-delete\"\n                        :disabled=\"actionLoading\"\n                      >\n                        Delete\n                      </button>\n                    </div>\n                    <div class=\"review-status\" v-else>\n                      <span\n                        :class=\"review.isApproved ? 'approved' : 'pending'\"\n                        class=\"status-badge\"\n                      >\n                        {{ review.isApproved ? \"Approved\" : \"Pending\" }}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Change Password View -->\n        <div\n          v-if=\"selectedMenu === 'changePassword'\"\n          class=\"password-section-wrapper\"\n        >\n          <div class=\"section-card password-card\">\n            <div class=\"section-header\">\n              <h3>Update Your Password</h3>\n            </div>\n\n            <form @submit.prevent=\"handleChangePassword\" class=\"password-form\">\n              <div v-if=\"passwordError\" class=\"alert error\">\n                {{ passwordError }}\n              </div>\n              <div v-if=\"passwordSuccess\" class=\"alert success\">\n                {{ passwordSuccess }}\n              </div>\n\n              <div class=\"form-group\">\n                <label>Current Password</label>\n                <div class=\"input-wrapper\">\n                  <span class=\"input-icon\">🔒</span>\n                  <input\n                    type=\"password\"\n                    v-model=\"passwordForm.currentPassword\"\n                    required\n                    placeholder=\"Enter current password\"\n                  />\n                </div>\n              </div>\n\n              <div class=\"form-group\">\n                <label>New Password</label>\n                <div class=\"input-wrapper\">\n                  <span class=\"input-icon\">🔑</span>\n                  <input\n                    type=\"password\"\n                    v-model=\"passwordForm.newPassword\"\n                    required\n                    placeholder=\"Enter new password\"\n                  />\n                </div>\n                <small class=\"hint\"\n                  >At least 8 chars, uppercase, lowercase, number & special\n                  char.</small\n                >\n              </div>\n\n              <div class=\"form-group\">\n                <label>Confirm New Password</label>\n                <div class=\"input-wrapper\">\n                  <span class=\"input-icon\">✅</span>\n                  <input\n                    type=\"password\"\n                    v-model=\"passwordForm.confirmPassword\"\n                    required\n                    placeholder=\"Confirm new password\"\n                  />\n                </div>\n              </div>\n\n              <div class=\"form-actions\">\n                <button\n                  type=\"submit\"\n                  class=\"btn-primary\"\n                  :disabled=\"passwordLoading\"\n                >\n                  <span v-if=\"passwordLoading\">Updating...</span>\n                  <span v-else>Update Password</span>\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      </div>\n    </main>\n\n    <!-- Modals -->\n    <div\n      v-if=\"showAddProductModal\"\n      class=\"modal-backdrop\"\n      @click=\"showAddProductModal = false\"\n    >\n      <div class=\"modal-panel\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>Add New Product</h3>\n          <button class=\"close-btn\" @click=\"showAddProductModal = false\">\n            ×\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <AddProduct :is-modal=\"true\" @close=\"closeAddProductModal\" />\n        </div>\n      </div>\n    </div>\n\n    <div\n      v-if=\"showListProductsModal\"\n      class=\"modal-backdrop\"\n      @click=\"showListProductsModal = false\"\n    >\n      <div class=\"modal-panel large\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>Product Catalog</h3>\n          <button class=\"close-btn\" @click=\"showListProductsModal = false\">\n            ×\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <ProductList\n            :is-modal=\"true\"\n            @close=\"closeListProductsModal\"\n            @edit=\"openEditProductModal\"\n          />\n        </div>\n      </div>\n    </div>\n\n    <div\n      v-if=\"showEditProductModal\"\n      class=\"modal-backdrop\"\n      @click=\"showEditProductModal = false\"\n    >\n      <div class=\"modal-panel\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>Edit Product</h3>\n          <button class=\"close-btn\" @click=\"showEditProductModal = false\">\n            ×\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <ProductEdit\n            :product-id=\"editProductId\"\n            @updated=\"handleProductUpdated\"\n          />\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport \"@/assets/styles/AdminPage.css\";\nimport axios from \"axios\";\nimport socket from \"@/socket\";\nimport AddProduct from \"@/views/AddProduct.vue\";\nimport ProductList from \"@/views/ProductList.vue\";\nimport ProductEdit from \"@/views/ProductEdit.vue\";\nimport ProductCategory from \"@/views/AddCategory.vue\";\nimport StaffManagement from \"@/views/StaffManagement.vue\";\n// eslint-disable-next-line no-unused-vars\nimport AdminOrders from \"@/views/AdminOrders.vue\";\nimport AdminLeaves from \"@/views/AdminLeaves.vue\";\nimport ChatWindow from \"@/views/ChatWindow.vue\";\n\nconst API_BASE_URL = \"http://localhost:5000/api\";\n\nexport default {\n  name: \"AdminPage\",\n  components: {\n    AddProduct,\n    ProductList,\n    ProductEdit,\n    ProductCategory,\n    StaffManagement,\n    AdminOrders,\n    AdminLeaves,\n    ChatWindow,\n  },\n  data() {\n    return {\n      selectedMenu: \"dashboard\",\n      showAddProductModal: false,\n      showListProductsModal: false,\n      showEditProductModal: false,\n      editProductId: null,\n      dashboardLoading: false,\n\n      // Stats\n      totalProducts: 0,\n      totalCategories: 0,\n      totalStaff: 0,\n      activeStaff: 0,\n      pendingLeaves: 0,\n      approvedLeaves: 0,\n      totalInventory: 0,\n      unreadMessageCount: 0,\n      totalEnquiries: 0,\n      pendingReviews: 0,\n      totalPurchases: 0,\n      totalProfit: 0,\n      salesTimeframe: \"all\",\n      analyticsData: null,\n      displayedPurchases: 0,\n      displayedProfit: 0,\n      reviewTab: \"pending\",\n      reviewsLoading: false,\n      currentReviews: [],\n      actionLoading: false,\n\n      messageInterval: null,\n\n      // Password Change\n      passwordForm: {\n        currentPassword: \"\",\n        newPassword: \"\",\n        confirmPassword: \"\",\n      },\n      passwordError: \"\",\n      passwordSuccess: \"\",\n      passwordLoading: false,\n    };\n  },\n  mounted() {\n    this.fetchDashboardStats();\n    this.fetchUnreadMessages();\n    this.messageInterval = setInterval(() => {\n      this.fetchUnreadMessages();\n    }, 5000); // Reduced frequency\n  },\n  beforeUnmount() {\n    if (this.messageInterval) clearInterval(this.messageInterval);\n  },\n  methods: {\n    getPageTitle(menu) {\n      const titles = {\n        dashboard: \"Dashboard Overview\",\n        addProduct: \"Add New Product\",\n        listProducts: \"Product Catalog\",\n        addCategory: \"Category Management\",\n        staffManagement: \"Staff Management\",\n        orders: \"Order Management\",\n        \"approve-leaves\": \"Leave Requests\",\n        chat: \"Messages & Communications\",\n        changePassword: \"Change Password\",\n      };\n      return titles[menu] || \"Dashboard\";\n    },\n    async handleChangePassword() {\n      this.passwordError = \"\";\n      this.passwordSuccess = \"\";\n\n      if (this.passwordForm.newPassword !== this.passwordForm.confirmPassword) {\n        this.passwordError = \"New passwords do not match.\";\n        return;\n      }\n\n      this.passwordLoading = true;\n\n      try {\n        const token = localStorage.getItem(\"token\");\n        const res = await axios.post(\n          `${API_BASE_URL}/auth/change-password`,\n          {\n            currentPassword: this.passwordForm.currentPassword,\n            newPassword: this.passwordForm.newPassword,\n          },\n          {\n            headers: { Authorization: `Bearer ${token}` },\n          }\n        );\n\n        this.passwordSuccess = res.data.msg || \"Password changed successfully.\";\n        this.passwordForm = {\n          currentPassword: \"\",\n          newPassword: \"\",\n          confirmPassword: \"\",\n        };\n      } catch (err) {\n        this.passwordError =\n          err.response?.data?.msg || \"Failed to change password.\";\n      } finally {\n        this.passwordLoading = false;\n      }\n    },\n    async fetchDashboardStats() {\n      this.dashboardLoading = true;\n      try {\n        const [\n          productsRes,\n          categoriesRes,\n          staffRes,\n          leavesRes,\n          reviewsRes,\n          salesRes,\n        ] = await Promise.all([\n          axios.get(`${API_BASE_URL}/products/getproduct`),\n          axios.get(`${API_BASE_URL}/categories`),\n          axios.get(`${API_BASE_URL}/staff`),\n          axios.get(`${API_BASE_URL}/leaves/all`),\n          axios.get(`${API_BASE_URL}/reviews/admin/pending`, {\n            headers: {\n              Authorization: `Bearer ${localStorage.getItem(\"token\")}`,\n            },\n          }),\n          axios.get(`${API_BASE_URL}/orders/admin/sales-analytics`, {\n            headers: {\n              Authorization: `Bearer ${localStorage.getItem(\"token\")}`,\n            },\n          }),\n        ]);\n\n        if (productsRes.data.success && productsRes.data.products) {\n          this.totalProducts = productsRes.data.products.length;\n          this.totalInventory = productsRes.data.products.reduce(\n            (sum, p) => sum + (p.quantity || 0),\n            0\n          );\n        }\n\n        if (Array.isArray(categoriesRes.data)) {\n          this.totalCategories = categoriesRes.data.length;\n        }\n\n        if (staffRes.data.success && Array.isArray(staffRes.data.staff)) {\n          this.totalStaff = staffRes.data.staff.length;\n          this.activeStaff = staffRes.data.staff.filter(\n            (s) => s.status === \"active\"\n          ).length;\n        }\n\n        if (Array.isArray(leavesRes.data)) {\n          this.pendingLeaves = leavesRes.data.filter(\n            (l) => l.status === \"Pending\"\n          ).length;\n          this.approvedLeaves = leavesRes.data.filter(\n            (l) => l.status === \"Approved\"\n          ).length;\n        }\n\n        if (Array.isArray(reviewsRes.data)) {\n          this.pendingReviews = reviewsRes.data.length;\n        }\n\n        if (salesRes.data) {\n          this.analyticsData = salesRes.data;\n          this.totalPurchases = salesRes.data.totalPurchases;\n          this.totalProfit = salesRes.data.totalProfit;\n          this.updateDisplayedStats();\n        }\n      } catch (error) {\n        console.error(\"Error loading stats:\", error);\n      } finally {\n        this.dashboardLoading = false;\n      }\n    },\n    updateDisplayedStats() {\n      if (!this.analyticsData) return;\n\n      if (this.salesTimeframe === \"all\") {\n        this.displayedPurchases = this.totalPurchases;\n        this.displayedProfit = this.totalProfit;\n      } else {\n        const now = new Date();\n        let key = \"\";\n        let dataSet = null;\n\n        if (this.salesTimeframe === \"today\") {\n          key = now.toISOString().split(\"T\")[0];\n          dataSet = this.analyticsData.daily;\n        } else if (this.salesTimeframe === \"month\") {\n          key = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(\n            2,\n            \"0\"\n          )}`;\n          dataSet = this.analyticsData.monthly;\n        } else if (this.salesTimeframe === \"year\") {\n          key = now.getFullYear().toString();\n          dataSet = this.analyticsData.yearly;\n        }\n\n        if (dataSet) {\n          this.displayedPurchases = dataSet.purchases[key] || 0;\n          this.displayedProfit = dataSet.profit[key] || 0;\n        }\n      }\n    },\n    async fetchUnreadMessages() {\n      try {\n        const token = localStorage.getItem(\"token\");\n        if (!token) return;\n        const res = await axios.get(\n          \"http://localhost:5000/api/messages/unread-count\",\n          {\n            headers: { Authorization: `Bearer ${token}` },\n          }\n        );\n        if (res.data.success) this.unreadMessageCount = res.data.unreadCount;\n      } catch (e) {\n        console.error(\"Msg Error\", e);\n      }\n    },\n    logout() {\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"user\");\n      this.$router.push(\"/\");\n    },\n    closeAddProductModal() {\n      this.showAddProductModal = false;\n      this.fetchDashboardStats();\n    },\n    closeListProductsModal() {\n      this.showListProductsModal = false;\n      this.fetchDashboardStats();\n    },\n    openEditProductModal(id) {\n      this.editProductId = id;\n      this.showEditProductModal = true;\n    },\n    handleProductUpdated() {\n      this.showEditProductModal = false;\n      this.showListProductsModal = false;\n      this.fetchDashboardStats();\n    },\n  },\n};\n</script>\n"],"mappings":";;;;AAglBA,OAAO,+BAA+B;AACtC,OAAOA,KAAI,MAAO,OAAO;AACzB,OAAOC,MAAK,MAAO,UAAU;AAC7B,OAAOC,UAAS,MAAO,wBAAwB;AAC/C,OAAOC,WAAU,MAAO,yBAAyB;AACjD,OAAOC,WAAU,MAAO,yBAAyB;AACjD,OAAOC,eAAc,MAAO,yBAAyB;AACrD,OAAOC,eAAc,MAAO,6BAA6B;AACzD;AACA,OAAOC,WAAU,MAAO,yBAAyB;AACjD,OAAOC,WAAU,MAAO,yBAAyB;AACjD,OAAOC,UAAS,MAAO,wBAAwB;AAE/C,MAAMC,YAAW,GAAI,2BAA2B;AAEhD,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,UAAU,EAAE;IACVV,UAAU;IACVC,WAAW;IACXC,WAAW;IACXC,eAAe;IACfC,eAAe;IACfC,WAAW;IACXC,WAAW;IACXC;EACF,CAAC;EACDI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,WAAW;MACzBC,mBAAmB,EAAE,KAAK;MAC1BC,qBAAqB,EAAE,KAAK;MAC5BC,oBAAoB,EAAE,KAAK;MAC3BC,aAAa,EAAE,IAAI;MACnBC,gBAAgB,EAAE,KAAK;MAEvB;MACAC,aAAa,EAAE,CAAC;MAChBC,eAAe,EAAE,CAAC;MAClBC,UAAU,EAAE,CAAC;MACbC,WAAW,EAAE,CAAC;MACdC,aAAa,EAAE,CAAC;MAChBC,cAAc,EAAE,CAAC;MACjBC,cAAc,EAAE,CAAC;MACjBC,kBAAkB,EAAE,CAAC;MACrBC,cAAc,EAAE,CAAC;MACjBC,cAAc,EAAE,CAAC;MACjBC,cAAc,EAAE,CAAC;MACjBC,WAAW,EAAE,CAAC;MACdC,cAAc,EAAE,KAAK;MACrBC,aAAa,EAAE,IAAI;MACnBC,kBAAkB,EAAE,CAAC;MACrBC,eAAe,EAAE,CAAC;MAClBC,SAAS,EAAE,SAAS;MACpBC,cAAc,EAAE,KAAK;MACrBC,cAAc,EAAE,EAAE;MAClBC,aAAa,EAAE,KAAK;MAEpBC,eAAe,EAAE,IAAI;MAErB;MACAC,YAAY,EAAE;QACZC,eAAe,EAAE,EAAE;QACnBC,WAAW,EAAE,EAAE;QACfC,eAAe,EAAE;MACnB,CAAC;MACDC,aAAa,EAAE,EAAE;MACjBC,eAAe,EAAE,EAAE;MACnBC,eAAe,EAAE;IACnB,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,mBAAmB,CAAC,CAAC;IAC1B,IAAI,CAACC,mBAAmB,CAAC,CAAC;IAC1B,IAAI,CAACV,eAAc,GAAIW,WAAW,CAAC,MAAM;MACvC,IAAI,CAACD,mBAAmB,CAAC,CAAC;IAC5B,CAAC,EAAE,IAAI,CAAC,EAAE;EACZ,CAAC;EACDE,aAAaA,CAAA,EAAG;IACd,IAAI,IAAI,CAACZ,eAAe,EAAEa,aAAa,CAAC,IAAI,CAACb,eAAe,CAAC;EAC/D,CAAC;EACDc,OAAO,EAAE;IACPC,YAAYA,CAACC,IAAI,EAAE;MACjB,MAAMC,MAAK,GAAI;QACbC,SAAS,EAAE,oBAAoB;QAC/BC,UAAU